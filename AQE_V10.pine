//======================================================
// CHANGELOG
//======================================================
// V10.0 - UI Optimization
// ✓ Dashboard reduced 60%, essential info only
// ✓ Single background (Buy=Green, Sell=Red, Wait=None)
// ✓ SMC signals throttled (max 1 per 10 bars)
// ✓ Max 3 Order Blocks, max 2 FVGs
// ✓ Trade Map drawn only on new signals
// ✓ Max 1 label per type on screen
// ✓ Fusion Score moved to separate pane
// ✓ Simplified color palette (Green/Red/Yellow/Blue)
// ✓ All calculations/logic/AI/MTF/SMC preserved
//======================================================

indicator(
     "AQE V10.0 PRO | Fusion Intelligence",
     overlay=true,
     max_labels_count=500,
     max_boxes_count=500,
     max_lines_count=500,
     max_bars_back=500)

// ╔══════════════════════════════════════════════════════════════╗
// ║                    PART 0 - INPUT GROUPS                   ║
// ╚══════════════════════════════════════════════════════════════╝

// --- General Settings ---
generalGroup = "⚙️ الإعدادات العامة"
minimumScore = input.int(80, "الحد الأدنى للثقة", minval=50, maxval=100, group=generalGroup)
showTradeMap = input.bool(true, "إظهار خريطة الصفقة", group=generalGroup)

// --- AI Settings ---
aiGroup = "🤖 الذكاء الاصطناعي"
aiEnabled = input.bool(true, "تفعيل محرك الذكاء الاصطناعي", group=aiGroup)
aiSensitivity = input.int(70, "حساسية الذكاء الاصطناعي", minval=50, maxval=100, group=aiGroup)
aiMinConfidence = input.int(65, "الحد الأدنى لثقة الذكاء الاصطناعي", minval=50, maxval=90, group=aiGroup)

// --- Risk Settings ---
riskGroup = "📊 إدارة المخاطر"
accountSize = input.float(10000, "💰 حجم الحساب", group=riskGroup)
riskPercent = input.float(1.0, "📉 نسبة المخاطرة %", step=0.1, group=riskGroup)
riskMultiplier = input.float(1.5, "📏 مضاعف ATR للوقف", step=0.1, group=riskGroup)
enableBreakeven = input.bool(true, "🔄 تفعيل نقطة التعادل", group=riskGroup)
breakevenTrigger = input.float(1.0, "🎯 هدف التعادل (R)", step=0.1, group=riskGroup)
enablePartialExit = input.bool(true, "📤 تفعيل جني أرباح جزئي", group=riskGroup)
partialExitPercent = input.float(50, "نسبة الجني الجزئي %", step=10, group=riskGroup)

// --- Dashboard Settings ---
dashboardGroup = "📋 لوحة التحكم"
showDashboard = input.bool(true, "إظهار لوحة التحكم الاحترافية", group=dashboardGroup)
dashboardPosition = input.string("top_right", "موقع لوحة التحكم", options=["top_right", "top_left", "bottom_right", "bottom_left"], group=dashboardGroup)

// --- MTF Settings ---
mtfGroup = "🕐 الإطارات الزمنية المتعددة"
enableMTF = input.bool(true, "تفعيل تحليل الإطارات المتعددة", group=mtfGroup)
mtfMinAlignment = input.int(8, "الحد الأدنى لتوافق الإطارات", minval=1, maxval=16, group=mtfGroup)

// --- Smart Money Settings ---
smartMoneyGroup = "💎 مفاهيم المؤسسات"
enableSmartMoney = input.bool(true, "تفعيل تحليل المؤسسات", group=smartMoneyGroup)
showSMC = input.bool(true, "إظهار إشارات المؤسسات", group=smartMoneyGroup)
smcSensitivity = input.int(3, "حساسية إشارات المؤسسات", minval=1, maxval=5, group=smartMoneyGroup)

// --- Smart Money Pro Settings (NEW) ---
smcProGroup = "💠 سمارت موني برو (SMC Pro)"
showInternalStructure = input.bool(true, "إظهار الهيكل الداخلي (Internal)", group=smcProGroup)
showExternalStructure = input.bool(true, "إظهار الهيكل الخارجي (External)", group=smcProGroup)
externalSwingLen = input.int(10, "طول القمم/القيعان الخارجية", minval=3, maxval=50, group=smcProGroup)
internalSwingLen = input.int(3, "طول القمم/القيعان الداخلية", minval=2, maxval=10, group=smcProGroup)
showLiquidityGrab = input.bool(true, "إظهار سحب السيولة الحقيقي (Liquidity Grab)", group=smcProGroup)
showInducement = input.bool(true, "إظهار الإغراء (Inducement)", group=smcProGroup)
showBreakerBlocks = input.bool(true, "إظهار Breaker Blocks", group=smcProGroup)
showMitigationBlocks = input.bool(true, "إظهار Mitigation Blocks", group=smcProGroup)
showRejectionBlocks = input.bool(true, "إظهار Rejection Blocks", group=smcProGroup)
rejectionWickRatio = input.float(2.0, "نسبة الذيل للجسم (Rejection)", step=0.1, minval=1.0, group=smcProGroup)

// --- Volume Settings ---
volumeGroup = "📈 تحليل الحجم"
enableVolumeAnalysis = input.bool(true, "تفعيل تحليل الحجم", group=volumeGroup)
volumeThreshold = input.float(1.5, "عتبة الحجم المؤسسي", step=0.1, group=volumeGroup)

// --- Trend Settings ---
trendGroup = "📉 محرك الاتجاه"
enableADX = input.bool(true, "تفعيل ADX", group=trendGroup)
adxThreshold = input.int(25, "عتبة ADX", minval=15, maxval=50, group=trendGroup)

// --- Session Settings ---
sessionGroup = "🌍 جلسات التداول"
showSessions = input.bool(true, "إظهار الجلسات", group=sessionGroup)

// --- Trailing Settings ---
trailGroup = "🛡️ الحماية المتحركة"
enableTrail = input.bool(true, "تفعيل الوقف المتحرك", group=trailGroup)
trailATR = input.float(1.2, "مضاعف ATR المتحرك", step=0.1, group=trailGroup)
trailActivation = input.float(0.5, "تفعيل بعد (R)", step=0.1, group=trailGroup)

// --- Smart Exit Settings ---
exitGroup = "🚪 الخروج الذكي"
useSmartExit = input.bool(true, "تفعيل الخروج الذكي", group=exitGroup)
exitRSI = input.int(45, "مستوى RSI للخروج", group=exitGroup)

// --- Signal Quality Filter Settings (NEW) ---
filterGroup = "🎯 فلتر جودة الإشارة"
requireStrongTrend = input.bool(true, "منع الإشارات في ترند ضعيف", group=filterGroup)
maxEmaDistanceATR = input.float(2.5, "أقصى بعد عن EMA50 (بوحدة ATR)", step=0.1, group=filterGroup)
requireLiquidityOK = input.bool(true, "منع الإشارات بدون سيولة مناسبة", group=filterGroup)
requireMarketReversal = input.bool(true, "منع تكرار الإشارة حتى ينعكس السوق", group=filterGroup)
requireInstitutionalConfluence = input.bool(true, "تفعيل فلتر الدخول المؤسسي (Institutional Entry)", group=filterGroup)

// --- Market Regime Settings (NEW) ---
regimeGroup = "🧭 نظام الأنظمة السوقية"
showMarketRegime = input.bool(true, "تفعيل محرك الأنظمة السوقية", group=regimeGroup)
blockSignalsInDistribution = input.bool(true, "منع الشراء أثناء التوزيع (Distribution)", group=regimeGroup)
blockSignalsInAccumulation = input.bool(true, "منع البيع أثناء التجميع (Accumulation)", group=regimeGroup)

// --- Smart Session & Kill Zone Settings (NEW) ---
sessionKZGroup = "🕰️ الجلسات و Kill Zones الذكية"
restrictToKillZones = input.bool(false, "السماح بالإشارات داخل Kill Zones فقط", group=sessionKZGroup)
londonKZStart = input.int(7, "بداية لندن KZ", minval=0, maxval=23, group=sessionKZGroup)
londonKZEnd = input.int(10, "نهاية لندن KZ", minval=0, maxval=23, group=sessionKZGroup)
nyKZStart = input.int(13, "بداية نيويورك KZ", minval=0, maxval=23, group=sessionKZGroup)
nyKZEnd = input.int(16, "نهاية نيويورك KZ", minval=0, maxval=23, group=sessionKZGroup)

// --- Real Performance Statistics Settings (NEW) ---
statsGroup = "📈 إحصائيات الأداء الحقيقية"
enablePerformanceTracking = input.bool(true, "تفعيل تتبع الأداء الحقيقي (Win Rate / Expectancy)", group=statsGroup)
minSampleSize = input.int(20, "أدنى عدد صفقات لتفعيل معايرة الثقة الإحصائية", minval=5, maxval=200, group=statsGroup)

// --- Volume Profile Settings (NEW) ---
vpGroup = "📊 ملف الحجم (Volume Profile)"
showVolumeProfile = input.bool(true, "إظهار POC / VAH / VAL", group=vpGroup)
vpLookback = input.int(100, "نطاق ملف الحجم (شمعة)", minval=20, maxval=300, group=vpGroup)
vpBins = input.int(24, "عدد المستويات السعرية", minval=10, maxval=50, group=vpGroup)
vpValueAreaPercent = input.float(70, "نسبة منطقة القيمة %", minval=50, maxval=90, group=vpGroup)

// --- Liquidity Map Settings (NEW) ---
lmGroup = "🌊 خريطة السيولة الديناميكية"
showLiquidityMap = input.bool(true, "إظهار خريطة السيولة", group=lmGroup)

// --- Alert Settings ---
alertGroup = "🔔 التنبيهات"
alertBuy = input.bool(true, "تنبيه شراء", group=alertGroup)
alertSell = input.bool(true, "تنبيه بيع", group=alertGroup)
alertExit = input.bool(true, "تنبيه خروج", group=alertGroup)
alertSMC = input.bool(true, "تنبيه إشارات المؤسسات", group=alertGroup)
alertTrend = input.bool(true, "تنبيه تغير الاتجاه", group=alertGroup)

// ╔══════════════════════════════════════════════════════════════╗
// ║              PART 1 - GLOBAL CALCULATIONS                  ║
// ║              (UNCHANGED - ALL LOGIC PRESERVED)             ║
// ╚══════════════════════════════════════════════════════════════╝

// --- Core Technical Indicators ---
atrSmart = ta.atr(14)
ema50 = ta.ema(close, 50)
ema200 = ta.ema(close, 200)
rsiValue = ta.rsi(close, 14)
avgVolume = ta.sma(volume, 20)
highPool = ta.highest(high, 20)
lowPool = ta.lowest(low, 20)
vwapValue = ta.vwap(close)

// --- ta.change Calls ---
changeHigh = ta.change(high)
changeLow = ta.change(low)

// --- ADX Suite ---
adxLength = 14
trueRangeVal = ta.tr(true)

plusDM = changeHigh > changeLow and changeHigh > 0 ? changeHigh : 0
minusDM = changeLow > changeHigh and changeLow > 0 ? changeLow : 0

smoothedTR = ta.rma(trueRangeVal, adxLength)
smoothedPlusDM = ta.rma(plusDM, adxLength)
smoothedMinusDM = ta.rma(minusDM, adxLength)

diPlus = (smoothedPlusDM / smoothedTR) * 100
diMinus = (smoothedMinusDM / smoothedTR) * 100

dxValue = math.abs(diPlus - diMinus) / (diPlus + diMinus) * 100
adxValue = ta.rma(dxValue, adxLength)

// --- ta.rising / ta.falling Calls ---
risingClose10 = ta.rising(close, 10)
risingATR3 = ta.rising(atrSmart, 3)
fallingClose10 = ta.falling(close, 10)

risingADX5 = ta.rising(adxValue, 5)
fallingADX5 = ta.falling(adxValue, 5)

risingATR5 = ta.rising(atrSmart, 5)
fallingATR5 = ta.falling(atrSmart, 5)

fallingVolume3 = ta.falling(volume, 3)
fallingClose2 = ta.falling(close, 2)

// --- ta.sma Calls ---
smaHigh20 = ta.sma(high, 20)
smaLow20 = ta.sma(low, 20)
smaClose20 = ta.sma(close, 20)
smaATR20 = ta.sma(atrSmart, 20)

// --- Derived Calculations ---
emaSlope = (ema50 - ema50[5]) / ema50[5] * 100
relativeVolume = volume / avgVolume

// --- Fixed Missing Variables ---
vwapDiff = close - vwapValue
vwapDiffPercent = math.abs(vwapDiff) / vwapValue * 100
vwapFar = vwapDiffPercent > 1.5

atrTrendUp = risingClose10 and risingATR3
atrTrendDown = fallingClose10 and risingATR3

// ╔══════════════════════════════════════════════════════════════╗
// ║              PART 2 - SESSION ENGINE (UNCHANGED)           ║
// ╚══════════════════════════════════════════════════════════════╝

getSession(h) =>
    if h >= 1 and h < 9
        "آسيا"
    else if h >= 8 and h < 17
        "لندن"
    else if h >= 13 and h < 22
        "نيويورك"
    else
        "سيدني"

hourNow = hour(time(timeframe.period, syminfo.timezone))
sessionName = getSession(hourNow)
isKillZone = (hourNow >= londonKZStart and hourNow < londonKZEnd) or (hourNow >= nyKZStart and hourNow < nyKZEnd)
killZoneName = (hourNow >= londonKZStart and hourNow < londonKZEnd) ? "London KZ" : (hourNow >= nyKZStart and hourNow < nyKZEnd) ? "New York KZ" : "—"
sessionActive = true
passKillZoneFilter = not restrictToKillZones or isKillZone

// ╔══════════════════════════════════════════════════════════════╗
// ║              PART 3 - TREND ENGINE (UNCHANGED)             ║
// ╚══════════════════════════════════════════════════════════════╝

bullTrend = ema50 > ema200
bearTrend = ema50 < ema200
neutralTrend = not bullTrend and not bearTrend

trendStrong = adxValue > adxThreshold
trendVeryStrong = adxValue > 40
trendWeak = adxValue <= adxThreshold
trendStrengthPercent = math.min(100, math.round(adxValue * 2))

bullDI = diPlus > diMinus
bearDI = diMinus > diPlus

emaRising = emaSlope > 0.1
emaFalling = emaSlope < -0.1
emaFlat = math.abs(emaSlope) <= 0.1

trendWeakening = fallingADX5 and trendStrong
trendAcceleration = risingADX5 and adxValue > 20
trendMomentum = emaSlope * adxValue / 20

getMarketPhase() =>
    if trendVeryStrong and bullTrend
        "صاعد بقوة"
    else if trendVeryStrong and bearTrend
        "هابط بقوة"
    else if trendStrong and bullTrend
        "صاعد"
    else if trendStrong and bearTrend
        "هابط"
    else if trendWeakening and bullTrend
        "ضعف الصعود"
    else if trendWeakening and bearTrend
        "ضعف الهبوط"
    else if trendAcceleration and bullDI
        "تسارع صاعد"
    else if trendAcceleration and bearDI
        "تسارع هابط"
    else
        "عرضي"

marketPhase = getMarketPhase()

// ╔══════════════════════════════════════════════════════════════╗
// ║              PART 4 - LIQUIDITY ENGINE (UNCHANGED)         ║
// ╚══════════════════════════════════════════════════════════════╝

bullLiquidity = low < lowPool[1] and close > open
bearLiquidity = high > highPool[1] and close < open
liquiditySweepLong = low < lowPool[1] and close > highPool[1]
liquiditySweepShort = high > highPool[1] and close < lowPool[1]

// ╔══════════════════════════════════════════════════════════════╗
// ║              PART 5 - SMART MONEY ENGINE (UNCHANGED)       ║
// ╚══════════════════════════════════════════════════════════════╝

bullDisplacement = close > open and (close - open) > atrSmart * 0.8
bearDisplacement = close < open and (open - close) > atrSmart * 0.8

detectSwingHigh() =>
    high > high[1] and high > high[2] and high[1] >= high[3] and high[2] >= high[4]

detectSwingLow() =>
    low < low[1] and low < low[2] and low[1] <= low[3] and low[2] <= low[4]

swingHigh = detectSwingHigh()
swingLow = detectSwingLow()

var float lastSwingHigh = na
var float lastSwingLow = na
var int swingHighBar = na
var int swingLowBar = na

if swingHigh
    lastSwingHigh := high
    swingHighBar := bar_index

if swingLow
    lastSwingLow := low
    swingLowBar := bar_index

bullishBOS = close > lastSwingHigh and not na(lastSwingHigh) and bar_index > swingHighBar
bearishBOS = close < lastSwingLow and not na(lastSwingLow) and bar_index > swingLowBar

choChBull = close > high[smcSensitivity] and open < low[smcSensitivity]
choChBear = close < low[smcSensitivity] and open > high[smcSensitivity]

bullishOB = low < low[1] and close > open and close > (high[1] + low[1]) / 2 and volume > avgVolume
bearishOB = high > high[1] and close < open and close < (high[1] + low[1]) / 2 and volume > avgVolume

bullishFVG = low > high[2] and close > open and volume > avgVolume
bearishFVG = high < low[2] and close < open and volume > avgVolume

rangeHigh50 = ta.highest(high, 50)
rangeLow50 = ta.lowest(low, 50)
rangeMid = (rangeHigh50 + rangeLow50) / 2
inPremiumZone = close > rangeHigh50 * 0.618 + rangeLow50 * 0.382
inDiscountZone = close < rangeHigh50 * 0.382 + rangeLow50 * 0.618
inEquilibrium = not inPremiumZone and not inDiscountZone

equalHighs = math.abs(high - high[1]) < atrSmart * 0.15 and high > smaHigh20
equalLows = math.abs(low - low[1]) < atrSmart * 0.15 and low < smaLow20

// ╔══════════════════════════════════════════════════════════════╗
// ║        PART 5B - SMART MONEY PRO ENGINE (NEW)               ║
// ╚══════════════════════════════════════════════════════════════╝

// --- External / Internal Structure via real Pivots ---
ph_ext = ta.pivothigh(externalSwingLen, externalSwingLen)
pl_ext = ta.pivotlow(externalSwingLen, externalSwingLen)
ph_int = ta.pivothigh(internalSwingLen, internalSwingLen)
pl_int = ta.pivotlow(internalSwingLen, internalSwingLen)

var float extSwingHigh = na
var float extSwingLow = na
var float intSwingHigh = na
var float intSwingLow = na

if not na(ph_ext)
    extSwingHigh := ph_ext
if not na(pl_ext)
    extSwingLow := pl_ext
if not na(ph_int)
    intSwingHigh := ph_int
if not na(pl_int)
    intSwingLow := pl_int

// --- BOS Detection: External = Major structure, Internal = Minor structure ---
// FIX: استخراج ta.crossover/crossunder لمتغيرات مستقلة تُنفَّذ كل شمعة (بدل استخدامها
// داخل تعبير شرطي مع and قد يقصّر تنفيذها) - يضمن دقة واتساق الحسابات التاريخية
crossOverExtHigh = ta.crossover(close, extSwingHigh)
crossUnderExtLow = ta.crossunder(close, extSwingLow)
crossOverIntHigh = ta.crossover(close, intSwingHigh)
crossUnderIntLow = ta.crossunder(close, intSwingLow)

externalBullishBOS = showExternalStructure and not na(extSwingHigh) and crossOverExtHigh
externalBearishBOS = showExternalStructure and not na(extSwingLow) and crossUnderExtLow
internalBullishBOS = showInternalStructure and not na(intSwingHigh) and crossOverIntHigh
internalBearishBOS = showInternalStructure and not na(intSwingLow) and crossUnderIntLow

// --- Structure Bias & CHoCH (reversal) vs BOS (continuation) ---
var string extBias = "NONE"
var string intBias = "NONE"

externalCHoCHBull = externalBullishBOS and extBias == "BEAR"
externalCHoCHBear = externalBearishBOS and extBias == "BULL"
internalCHoCHBull = internalBullishBOS and intBias == "BEAR"
internalCHoCHBear = internalBearishBOS and intBias == "BULL"

if externalBullishBOS
    extBias := "BULL"
if externalBearishBOS
    extBias := "BEAR"
if internalBullishBOS
    intBias := "BULL"
if internalBearishBOS
    intBias := "BEAR"

// --- Real Liquidity Grab: wick sweep beyond pool + rejection close back inside ---
bullishLiquidityGrab = showLiquidityGrab and low < lowPool[1] and close > lowPool[1] and close > open
bearishLiquidityGrab = showLiquidityGrab and high > highPool[1] and close < highPool[1] and close < open

// --- Inducement: minor (internal) sweep in the direction of prevailing external bias, right before continuation ---
inducementBull = showInducement and not na(intSwingLow) and low < intSwingLow and close > intSwingLow and extBias == "BULL"
inducementBear = showInducement and not na(intSwingHigh) and high > intSwingHigh and close < intSwingHigh and extBias == "BEAR"

// (Rejection Block calculated in PART 6B, after bodySize/upperWick/lowerWick are defined)

// ╔══════════════════════════════════════════════════════════════╗
// ║              PART 6 - VOLUME ENGINE (UNCHANGED)            ║
// ╚══════════════════════════════════════════════════════════════╝

institutionalVolume = volume > avgVolume * volumeThreshold
volumeSpike = volume > avgVolume * 2.5
weakVolume = volume < avgVolume * 0.5
strongVolume = volume > avgVolume * 1.8

bodySize = math.abs(close - open)
upperWick = high - math.max(close, open)
lowerWick = math.min(close, open) - low

// --- Rejection Block: strong wick rejection exactly at a structural swing point ---
rejectionBull = showRejectionBlocks and swingLow and lowerWick > bodySize * rejectionWickRatio
rejectionBear = showRejectionBlocks and swingHigh and upperWick > bodySize * rejectionWickRatio

volumeDelta = close > open ? volume * (bodySize + upperWick) / math.max(high - low, 0.0001) : -volume * (bodySize + lowerWick) / math.max(high - low, 0.0001)
volumeDeltaSmooth = ta.sma(volumeDelta, 5)
positiveDelta = volumeDeltaSmooth > 0
negativeDelta = volumeDeltaSmooth < 0

buyingPressure = close > open ? volume * (close - open) / math.max(high - low, 0.0001) : 0
sellingPressure = close < open ? volume * (open - close) / math.max(high - low, 0.0001) : 0
netPressure = ta.sma(buyingPressure - sellingPressure, 10)
buyVolumeDominant = netPressure > 0
sellVolumeDominant = netPressure < 0

volumeClimax = volume > avgVolume * 3.0 and (close > smaClose20 or close < smaClose20)
volumeExhaustion = volume > avgVolume * 2.0 and fallingVolume3 and fallingClose2

smartVolumeBuy = volume > avgVolume * 1.3 and close > open and rsiValue > 50
smartVolumeSell = volume > avgVolume * 1.3 and close < open and rsiValue < 50

// --- Absorption: high volume with a small range candle (institutions absorbing liquidity) ---
absorptionBar = volume > avgVolume * 2.0 and bodySize < atrSmart * 0.3

// ╔══════════════════════════════════════════════════════════════╗
// ║              PART 7 - VOLATILITY ENGINE (UNCHANGED)        ║
// ╚══════════════════════════════════════════════════════════════╝

atrRising = risingATR5
atrFalling = fallingATR5
volatilityExpanding = atrSmart > smaATR20 * 1.2
volatilityContracting = atrSmart < smaATR20 * 0.8
volatilityNormal = not volatilityExpanding and not volatilityContracting

// ╔══════════════════════════════════════════════════════════════╗
// ║        PART 7B - MARKET REGIME ENGINE (NEW)                 ║
// ║  يصنف السوق: Trending / Ranging / Expansion / Compression /  ║
// ║  Distribution / Accumulation باستخدام المتغيرات الموجودة     ║
// ║  أصلاً (بدون request.security وبدون تكرار حسابات)            ║
// ╚══════════════════════════════════════════════════════════════╝

regimeTrending = trendStrong and (bullTrend or bearTrend)
regimeRanging = not trendStrong and not volatilityExpanding and not volatilityContracting
regimeExpansion = volatilityExpanding
regimeCompression = volatilityContracting and not trendStrong
regimeDistribution = not trendStrong and inPremiumZone and (negativeDelta or fallingVolume3)
regimeAccumulation = not trendStrong and inDiscountZone and (positiveDelta or not fallingVolume3)

getMarketRegime() =>
    string regime = "Ranging"
    if regimeDistribution
        regime := "Distribution"
    else if regimeAccumulation
        regime := "Accumulation"
    else if regimeCompression
        regime := "Compression"
    else if regimeExpansion and regimeTrending
        regime := "Expansion"
    else if regimeTrending
        regime := "Trending"
    regime

marketRegime = showMarketRegime ? getMarketRegime() : "Trending"

marketRegimeArabic = marketRegime == "Trending" ? "اتجاهي" : marketRegime == "Ranging" ? "عرضي" : marketRegime == "Expansion" ? "توسع" : marketRegime == "Compression" ? "انضغاط" : marketRegime == "Distribution" ? "توزيع" : "تجميع"

// فلتر: منع الشراء وقت التوزيع (علامة انعكاس هابط محتمل) ومنع البيع وقت التجميع
passRegimeFilterBuy = not showMarketRegime or not (blockSignalsInDistribution and marketRegime == "Distribution")
passRegimeFilterSell = not showMarketRegime or not (blockSignalsInAccumulation and marketRegime == "Accumulation")

// ╔══════════════════════════════════════════════════════════════╗
// ║              PART 8 - FUSION SCORE ENGINE (UNCHANGED)      ║
// ╚══════════════════════════════════════════════════════════════╝

calcComponent(condition, weight) =>
    condition ? weight : 0

float buyScore = 0.0
float sellScore = 0.0

buyScore += calcComponent(bullTrend, 7)
buyScore += calcComponent(bullDI, 4)
buyScore += calcComponent(emaRising, 4)
buyScore += calcComponent(trendStrong and bullTrend, 3)

sellScore += calcComponent(bearTrend, 7)
sellScore += calcComponent(bearDI, 4)
sellScore += calcComponent(emaFalling, 4)
sellScore += calcComponent(trendStrong and bearTrend, 3)

buyScore += calcComponent(rsiValue > 60, 6)
buyScore += calcComponent(rsiValue > 50 and rsiValue <= 60, 3)
buyScore += calcComponent(trendAcceleration, 3)

sellScore += calcComponent(rsiValue < 40, 6)
sellScore += calcComponent(rsiValue < 50 and rsiValue >= 40, 3)
sellScore += calcComponent(trendAcceleration and bearTrend, 3)

buyScore += calcComponent(institutionalVolume and close > open, 5)
buyScore += calcComponent(buyVolumeDominant, 4)
buyScore += calcComponent(positiveDelta, 3)
buyScore += calcComponent(smartVolumeBuy, 3)

sellScore += calcComponent(institutionalVolume and close < open, 5)
sellScore += calcComponent(sellVolumeDominant, 4)
sellScore += calcComponent(negativeDelta, 3)
sellScore += calcComponent(smartVolumeSell, 3)

buyScore += calcComponent(bullLiquidity, 6)
buyScore += calcComponent(liquiditySweepLong, 6)

sellScore += calcComponent(bearLiquidity, 6)
sellScore += calcComponent(liquiditySweepShort, 6)

buyScore += calcComponent(bullDisplacement, 10)
sellScore += calcComponent(bearDisplacement, 10)

buyScore += calcComponent(close > vwapValue, 4)
buyScore += calcComponent(close > vwapValue and vwapFar, 4)

sellScore += calcComponent(close < vwapValue, 4)
sellScore += calcComponent(close < vwapValue and vwapFar, 4)

buyScore += calcComponent(atrTrendUp, 5)
sellScore += calcComponent(atrTrendDown, 5)

buyScore += calcComponent(adxValue > 25 and bullDI, 5)
sellScore += calcComponent(adxValue > 25 and bearDI, 5)

buyScore += calcComponent(volatilityContracting and close > ema50, 3)
buyScore += calcComponent(volatilityExpanding and bullTrend, 2)

sellScore += calcComponent(volatilityContracting and close < ema50, 3)
sellScore += calcComponent(volatilityExpanding and bearTrend, 2)

buyScore += calcComponent(inDiscountZone, 3)
buyScore += calcComponent(bullishBOS, 2)

sellScore += calcComponent(inPremiumZone, 3)
sellScore += calcComponent(bearishBOS, 2)

buyScore += calcComponent(volumeSpike and close > open, 2)
buyScore += calcComponent(strongVolume and not volumeExhaustion, 3)

sellScore += calcComponent(volumeSpike and close < open, 2)
sellScore += calcComponent(strongVolume and not volumeExhaustion, 3)

buyScore := math.min(buyScore, 100)
sellScore := math.min(sellScore, 100)

fusionScoreBase = math.max(buyScore, sellScore)

// ╔══════════════════════════════════════════════════════════════╗
// ║              PART 9 - MTF INTELLIGENCE ENGINE (UNCHANGED)  ║
// ╚══════════════════════════════════════════════════════════════╝

getMTF_EMA(tf, length) =>
    request.security(syminfo.tickerid, tf, ta.ema(close, length))

getMTF_RSI(tf, length) =>
    request.security(syminfo.tickerid, tf, ta.rsi(close, length))

getMTF_Volume(tf) =>
    [request.security(syminfo.tickerid, tf, volume), request.security(syminfo.tickerid, tf, ta.sma(volume, 20))]

ema50_5m = getMTF_EMA("5", 50)
ema200_5m = getMTF_EMA("5", 200)
ema50_15m = getMTF_EMA("15", 50)
ema200_15m = getMTF_EMA("15", 200)
ema50_1h = getMTF_EMA("60", 50)
ema200_1h = getMTF_EMA("60", 200)
ema50_4h = getMTF_EMA("240", 50)
ema200_4h = getMTF_EMA("240", 200)

rsi_5m = getMTF_RSI("5", 14)
rsi_15m = getMTF_RSI("15", 14)
rsi_1h = getMTF_RSI("60", 14)
rsi_4h = getMTF_RSI("240", 14)

[vol_5m, avgVol_5m] = getMTF_Volume("5")
[vol_15m, avgVol_15m] = getMTF_Volume("15")
[vol_1h, avgVol_1h] = getMTF_Volume("60")
[vol_4h, avgVol_4h] = getMTF_Volume("240")

bull_5m = ema50_5m > ema200_5m
bull_15m = ema50_15m > ema200_15m
bull_1h = ema50_1h > ema200_1h
bull_4h = ema50_4h > ema200_4h

bear_5m = ema50_5m < ema200_5m
bear_15m = ema50_15m < ema200_15m
bear_1h = ema50_1h < ema200_1h
bear_4h = ema50_4h < ema200_4h

rsiBull_5m = rsi_5m > 50
rsiBull_15m = rsi_15m > 50
rsiBull_1h = rsi_1h > 50
rsiBull_4h = rsi_4h > 50

rsiBear_5m = rsi_5m < 50
rsiBear_15m = rsi_15m < 50
rsiBear_1h = rsi_1h < 50
rsiBear_4h = rsi_4h < 50

volAbove_5m = vol_5m > avgVol_5m
volAbove_15m = vol_15m > avgVol_15m
volAbove_1h = vol_1h > avgVol_1h
volAbove_4h = vol_4h > avgVol_4h

int bullAlignment = 0
int bearAlignment = 0

if bull_5m
    bullAlignment += 1
if bull_15m
    bullAlignment += 1
if bull_1h
    bullAlignment += 1
if bull_4h
    bullAlignment += 1

if bear_5m
    bearAlignment += 1
if bear_15m
    bearAlignment += 1
if bear_1h
    bearAlignment += 1
if bear_4h
    bearAlignment += 1

if rsiBull_5m
    bullAlignment += 1
if rsiBull_15m
    bullAlignment += 1
if rsiBull_1h
    bullAlignment += 1
if rsiBull_4h
    bullAlignment += 1

if rsiBear_5m
    bearAlignment += 1
if rsiBear_15m
    bearAlignment += 1
if rsiBear_1h
    bearAlignment += 1
if rsiBear_4h
    bearAlignment += 1

if volAbove_5m
    bullAlignment += 1
if volAbove_15m
    bullAlignment += 1
if volAbove_1h
    bullAlignment += 1
if volAbove_4h
    bullAlignment += 1

if volAbove_5m
    bearAlignment += 1
if volAbove_15m
    bearAlignment += 1
if volAbove_1h
    bearAlignment += 1
if volAbove_4h
    bearAlignment += 1

bullStrengthMTF = bullAlignment * (100 / 12)
bearStrengthMTF = bearAlignment * (100 / 12)
mtfConfidence = math.max(bullStrengthMTF, bearStrengthMTF)

strongBullMTF = bullAlignment >= mtfMinAlignment
strongBearMTF = bearAlignment >= mtfMinAlignment

weight5m = 10
weight15m = 20
weight1h = 30
weight4h = 40

bullWeightedStrength = (bull_5m ? weight5m : 0) + (bull_15m ? weight15m : 0) + (bull_1h ? weight1h : 0) + (bull_4h ? weight4h : 0)
bearWeightedStrength = (bear_5m ? weight5m : 0) + (bear_15m ? weight15m : 0) + (bear_1h ? weight1h : 0) + (bear_4h ? weight4h : 0)

mtfTrendBull = bullWeightedStrength > bearWeightedStrength
mtfTrendBear = bearWeightedStrength > bullWeightedStrength
mtfTotalStrength = math.max(bullWeightedStrength, bearWeightedStrength)

// ╔══════════════════════════════════════════════════════════════╗
// ║              PART 10 - AI DECISION ENGINE (UNCHANGED)      ║
// ╚══════════════════════════════════════════════════════════════╝

mtfBonus = math.round(mtfTotalStrength * 0.15)
fusionScore = math.min(100, fusionScoreBase + mtfBonus)

aiConfidenceRaw = math.min(100, math.round(fusionScore * 0.5 + mtfConfidence * 0.3 + (trendStrong ? 20 : 10)))

institutionalScore = math.min(100, math.round(
    (institutionalVolume ? 35 : 15) +
    (smartVolumeBuy or smartVolumeSell ? 25 : 10) +
    (buyVolumeDominant and bullTrend ? 20 : sellVolumeDominant and bearTrend ? 20 : 5) +
    (positiveDelta and bullTrend ? 20 : negativeDelta and bearTrend ? 20 : 5)))

trendScore = math.min(100, math.round(
    trendStrengthPercent * 0.35 +
    (bullDI and bullTrend ? 25 : bearDI and bearTrend ? 25 : 5) +
    (emaRising and bullTrend ? 20 : emaFalling and bearTrend ? 20 : 5) +
    (trendAcceleration ? 20 : 10)))

riskScore = math.min(100, math.round(riskPercent <= 1 ? 100 : riskPercent <= 2 ? 70 : 40))

winProbability = math.min(95, math.round(fusionScore * 0.4 + mtfConfidence * 0.2 + trendScore * 0.2 + institutionalScore * 0.2))

finalAIScore = math.min(100, math.round(
    aiConfidenceRaw * 0.30 +
    institutionalScore * 0.25 +
    trendScore * 0.25 +
    riskScore * 0.10 +
    winProbability * 0.10))

aiDecisionRaw = buyScore >= minimumScore ? "BUY" : sellScore >= minimumScore ? "SELL" : "WAIT"

allowLong = (not enableMTF or strongBullMTF) and finalAIScore >= aiMinConfidence
allowShort = (not enableMTF or strongBearMTF) and finalAIScore >= aiMinConfidence

fusionDecisionRaw = aiDecisionRaw == "BUY" and allowLong ? "BUY" : aiDecisionRaw == "SELL" and allowShort ? "SELL" : "WAIT"

// ╔══════════════════════════════════════════════════════════════╗
// ║        PART 10B - SIGNAL QUALITY FILTER (NEW)              ║
// ║  يمنع: الترند الضعيف / البعد عن EMA50 / السيولة الضعيفة    ║
// ║  ويمنع تكرار نفس الإشارة حتى ينعكس السوق فعلياً             ║
// ╚══════════════════════════════════════════════════════════════╝

// 1) فلتر قوة الترند
passTrendFilter = not requireStrongTrend or trendStrong

// 2) فلتر البعد عن EMA50 (لا تدخل إذا السعر ابتعد كثيراً = ملاحقة السعر)
emaDistanceATR = atrSmart > 0 ? math.abs(close - ema50) / atrSmart : 0
passEmaDistanceFilter = emaDistanceATR <= maxEmaDistanceATR

// 3) فلتر السيولة المناسبة لكل اتجاه
liquidityOKBuy = institutionalVolume or bullLiquidity or liquiditySweepLong
liquidityOKSell = institutionalVolume or bearLiquidity or liquiditySweepShort
passLiquidityFilterBuy = not requireLiquidityOK or liquidityOKBuy
passLiquidityFilterSell = not requireLiquidityOK or liquidityOKSell

// 3B) فلتر الدخول المؤسسي: يشترط توافق حجم مؤسسي مع Displacement أو OB أو Liquidity Grab حقيقي
institutionalConfluenceBuy = institutionalVolume and (bullDisplacement or bullishOB or bullishLiquidityGrab)
institutionalConfluenceSell = institutionalVolume and (bearDisplacement or bearishOB or bearishLiquidityGrab)
passInstitutionalFilterBuy = not requireInstitutionalConfluence or institutionalConfluenceBuy
passInstitutionalFilterSell = not requireInstitutionalConfluence or institutionalConfluenceSell

passQualityFilterBuy = passTrendFilter and passEmaDistanceFilter and passLiquidityFilterBuy and passRegimeFilterBuy and passInstitutionalFilterBuy and passKillZoneFilter
passQualityFilterSell = passTrendFilter and passEmaDistanceFilter and passLiquidityFilterSell and passRegimeFilterSell and passInstitutionalFilterSell and passKillZoneFilter

// 4) حالة الصفقة النشطة + تثبيت مستويات الدخول/الوقف/الأهداف وقت الدخول فقط
// FIX: الكود الأصلي كان يعيد حساب entryPrice/SL/TP من close في كل شمعة حتى أثناء
// استمرار الصفقة، فكانت مستويات الوقف المتحرك والخروج الذكي والداشبورد كلها
// "تلاحق" السعر الحالي بدل الالتزام بمستويات الدخول الحقيقية. الحل: نثبّتها في
// متغيرات var فقط لحظة الدخول، وتبقى ثابتة طوال عمر الصفقة.
var string activeSignal = "NONE" // "BUY" / "SELL" / "NONE"
var float tradeEntry = na
var float tradeSL = na
var float tradeTP1 = na
var float tradeTP2 = na
var float tradeTP3 = na

rawLongCondition = fusionDecisionRaw == "BUY" and passQualityFilterBuy
rawShortCondition = fusionDecisionRaw == "SELL" and passQualityFilterSell

// السماح بإشارة جديدة فقط لو ما فيه إشارة فعالة بنفس الاتجاه (أو الفلتر معطّل)
longEntryFiltered = rawLongCondition and (not requireMarketReversal or activeSignal != "BUY")
shortEntryFiltered = rawShortCondition and (not requireMarketReversal or activeSignal != "SELL")

if longEntryFiltered
    activeSignal := "BUY"
    tradeEntry := close
    tradeSL := close - atrSmart * riskMultiplier
    tradeRiskLongInit = close - tradeSL
    tradeTP1 := close + tradeRiskLongInit * 1.0
    tradeTP2 := close + tradeRiskLongInit * 2.0
    tradeTP3 := close + tradeRiskLongInit * 3.0

if shortEntryFiltered
    activeSignal := "SELL"
    tradeEntry := close
    tradeSL := close + atrSmart * riskMultiplier
    tradeRiskShortInit = tradeSL - close
    tradeTP1 := close - tradeRiskShortInit * 1.0
    tradeTP2 := close - tradeRiskShortInit * 2.0
    tradeTP3 := close - tradeRiskShortInit * 3.0

// FIX: إغلاق الصفقة فعلياً عند تحقق الوقف أو الهدف الأخير أو انعكاس الهيكل الخارجي (extBias)
// بدل الاعتماد فقط على تقاطع EMA50/200 البطيء - هذا يحقق شرط "لا تكرار حتى يتغير هيكل السوق"
// بمعناه الحقيقي (SMC) وليس مجرد مؤشر اتجاه كلاسيكي.
if activeSignal == "BUY" and not longEntryFiltered
    if low <= tradeSL or high >= tradeTP3 or extBias == "BEAR"
        activeSignal := "NONE"
if activeSignal == "SELL" and not shortEntryFiltered
    if high >= tradeSL or low <= tradeTP3 or extBias == "BULL"
        activeSignal := "NONE"

inLongPosition = activeSignal == "BUY"
inShortPosition = activeSignal == "SELL"

fusionDecision = longEntryFiltered ? "BUY" : shortEntryFiltered ? "SELL" : "WAIT"

aiDecisionArabic = fusionDecision == "BUY" ? "شراء" : fusionDecision == "SELL" ? "بيع" : "انتظار"

// ╔══════════════════════════════════════════════════════════════╗
// ║   PART 10C - REAL PERFORMANCE STATISTICS ENGINE (NEW)       ║
// ║   Win Rate حقيقي + Trade Expectancy + معايرة الثقة إحصائياً  ║
// ╚══════════════════════════════════════════════════════════════╝

var float statWins = 0.0
var float statLosses = 0.0
var float statSumR = 0.0
var bool statOutcomeLogged = false

if enablePerformanceTracking
    if inLongPosition
        if not statOutcomeLogged
            if high >= tradeTP1
                statWins += 1
                statSumR += 1.0
                statOutcomeLogged := true
            else if low <= tradeSL
                statLosses += 1
                statSumR += -1.0
                statOutcomeLogged := true
    else if inShortPosition
        if not statOutcomeLogged
            if low <= tradeTP1
                statWins += 1
                statSumR += 1.0
                statOutcomeLogged := true
            else if high >= tradeSL
                statLosses += 1
                statSumR += -1.0
                statOutcomeLogged := true
    else
        statOutcomeLogged := false

statTotalTrades = statWins + statLosses
realWinRate = statTotalTrades > 0 ? (statWins / statTotalTrades) * 100 : na
realExpectancyR = statTotalTrades > 0 ? statSumR / statTotalTrades : na
statisticsReady = statTotalTrades >= minSampleSize

// #1 و #11: احتمالية/ثقة حقيقية مبنية على إحصائيات فعلية بمجرد توفر عينة كافية،
// وتستخدم تقدير النموذج (winProbability بالأوزان) فقط كبديل مؤقت قبل توفر البيانات
winProbabilityCalibrated = statisticsReady ? realWinRate : winProbability
calibratedConfidence = statisticsReady ? math.round(finalAIScore * 0.5 + realWinRate * 0.5) : finalAIScore

getAIGrade(score) =>
    if score >= 95
        "A+"
    else if score >= 90
        "A"
    else if score >= 80
        "B"
    else if score >= 70
        "C"
    else if score >= 60
        "D"
    else
        "F"

aiGrade = getAIGrade(calibratedConfidence)

// ╔══════════════════════════════════════════════════════════════╗
// ║              PART 11 - ENTRY & EXIT SIGNALS (UNCHANGED)    ║
// ╚══════════════════════════════════════════════════════════════╝

longEntry = fusionDecision == "BUY"
shortEntry = fusionDecision == "SELL"

// ملاحظة: entryPrice/longSL/.. هنا تُستخدم فقط لحظة الدخول (لرسم Trade Map والتسميات)
// وهي مطابقة لـ tradeEntry/tradeSL/tradeTP في تلك اللحظة بالضبط. أما لبقية عمر
// الصفقة (الوقف المتحرك/الخروج الذكي/الداشبورد) فتُستخدم tradeEntry/tradeSL/tradeTP
// الثابتة من PART 10B لأنها لا "تلاحق" السعر الحالي.
entryPrice = close

longSL = entryPrice - (atrSmart * riskMultiplier)
shortSL = entryPrice + (atrSmart * riskMultiplier)

longRisk = entryPrice - longSL
shortRisk = shortSL - entryPrice

longTP1 = entryPrice + longRisk * 1.0
longTP2 = entryPrice + longRisk * 2.0
longTP3 = entryPrice + longRisk * 3.0

shortTP1 = entryPrice - shortRisk * 1.0
shortTP2 = entryPrice - shortRisk * 2.0
shortTP3 = entryPrice - shortRisk * 3.0

riskReward = inLongPosition ? (tradeTP3 - tradeEntry) / math.max(tradeEntry - tradeSL, 0.0001) : inShortPosition ? (tradeEntry - tradeTP3) / math.max(tradeSL - tradeEntry, 0.0001) : na

riskCapital = accountSize * (riskPercent / 100)
stopDistance = inLongPosition ? tradeEntry - tradeSL : inShortPosition ? tradeSL - tradeEntry : na
positionSize = not na(stopDistance) and stopDistance > 0 ? riskCapital / stopDistance : na

riskDollar = not na(positionSize) ? positionSize * stopDistance : 0
rewardDollar = not na(positionSize) and not na(riskReward) ? riskDollar * riskReward : 0

// ╔══════════════════════════════════════════════════════════════╗
// ║              PART 12 - DYNAMIC STOP ENGINE (FIXED)          ║
// ║  FIX: يعتمد الآن على inLongPosition/inShortPosition + مستويات ║
// ║  الصفقة الثابتة (tradeEntry/tradeSL) بدل longEntry اللحظي     ║
// ║  الذي كان "ينبض" لشمعة واحدة فقط فيُلغي تفعيل التريل فوراً    ║
// ╚══════════════════════════════════════════════════════════════╝

trailDistance = atrSmart * trailATR
var float dynamicStop = na
var bool trailActive = false

if inLongPosition and not trailActive
    dynamicStop := close - trailDistance
    trailActive := true

if inShortPosition and not trailActive
    dynamicStop := close + trailDistance
    trailActive := true

if enableTrail and trailActive
    if inLongPosition
        if close >= tradeEntry + (tradeEntry - tradeSL) * trailActivation
            dynamicStop := math.max(dynamicStop, close - trailDistance)
    if inShortPosition
        if close <= tradeEntry - (tradeSL - tradeEntry) * trailActivation
            dynamicStop := math.min(dynamicStop, close + trailDistance)

if not inLongPosition and not inShortPosition
    trailActive := false
    dynamicStop := na

var bool breakevenActive = false

if enableBreakeven and inLongPosition and not breakevenActive
    if close >= tradeEntry + (tradeEntry - tradeSL) * breakevenTrigger
        dynamicStop := tradeEntry
        breakevenActive := true

if enableBreakeven and inShortPosition and not breakevenActive
    if close <= tradeEntry - (tradeSL - tradeEntry) * breakevenTrigger
        dynamicStop := tradeEntry
        breakevenActive := true

if not inLongPosition and not inShortPosition
    breakevenActive := false

protectionStatus = enableTrail and trailActive ? "متحرك" : breakevenActive ? "تعادل" : "ثابت"

// ╔══════════════════════════════════════════════════════════════╗
// ║              PART 13 - SMART EXIT ENGINE (FIXED)            ║
// ╚══════════════════════════════════════════════════════════════╝

inProfitLong = close > tradeEntry
inProfitShort = close < tradeEntry

weakLongMomentum = rsiValue < exitRSI
weakShortMomentum = rsiValue > (100 - exitRSI)

smartExitLong = inLongPosition and inProfitLong and (weakLongMomentum or volumeExhaustion)
smartExitShort = inShortPosition and inProfitShort and (weakShortMomentum or volumeExhaustion)

partialExitLong = inLongPosition and inProfitLong and close >= tradeTP1 and enablePartialExit
partialExitShort = inShortPosition and inProfitShort and close <= tradeTP1 and enablePartialExit

exitStatus = smartExitLong ? "خروج شراء" : smartExitShort ? "خروج بيع" : partialExitLong ? "جني جزئي" : partialExitShort ? "جني جزئي" : "مستمر"

// ╔══════════════════════════════════════════════════════════════╗
// ║              PART 14 - CHART VISUALIZATIONS (OPTIMIZED)    ║
// ║              SINGLE BACKGROUND ONLY                        ║
// ╚══════════════════════════════════════════════════════════════╝

// Single background: Green for BUY, Red for SELL, None for WAIT
// FIX: يعتمد على inLongPosition/inShortPosition (يغطي كامل مدة الصفقة) بدل longEntry اللحظي
bgColor = inLongPosition ? color.new(#00ff00, 96) : inShortPosition ? color.new(#ff0000, 96) : na
bgcolor(bgColor, title="AQE Signal")

// ╔══════════════════════════════════════════════════════════════╗
// ║              PART 15 - TRADE MAP (DRAWN ONLY ON NEW SIGNAL)║
// ╚══════════════════════════════════════════════════════════════╝

var line entryLine = na
var line stopLine = na
var line tp1Line = na
var line tp2Line = na
var line tp3Line = na
var label tradeLabel = na

// Detect new signal (transition from false to true)
newLongSignal = longEntry and not longEntry[1]
newShortSignal = shortEntry and not shortEntry[1]

if showTradeMap and (newLongSignal or newShortSignal)
    line.delete(entryLine)
    line.delete(stopLine)
    line.delete(tp1Line)
    line.delete(tp2Line)
    line.delete(tp3Line)
    label.delete(tradeLabel)

    if newLongSignal
        entryLine := line.new(bar_index, entryPrice, bar_index + 35, entryPrice, color=color.rgb(0, 120, 255), width=2, style=line.style_solid)
        stopLine := line.new(bar_index, longSL, bar_index + 35, longSL, color=color.rgb(255, 50, 50), width=1, style=line.style_dashed)
        tp1Line := line.new(bar_index, longTP1, bar_index + 35, longTP1, color=color.rgb(0, 200, 0), width=1, style=line.style_dashed)
        tp2Line := line.new(bar_index, longTP2, bar_index + 35, longTP2, color=color.rgb(0, 200, 0), width=1, style=line.style_dashed)
        tp3Line := line.new(bar_index, longTP3, bar_index + 35, longTP3, color=color.rgb(0, 200, 0), width=2, style=line.style_solid)
        tradeLabel := label.new(bar_index + 18, entryPrice, "شراء", style=label.style_label_center, color=color.rgb(0, 200, 0), textcolor=color.white, size=size.tiny)

    if newShortSignal
        entryLine := line.new(bar_index, entryPrice, bar_index + 35, entryPrice, color=color.rgb(0, 120, 255), width=2, style=line.style_solid)
        stopLine := line.new(bar_index, shortSL, bar_index + 35, shortSL, color=color.rgb(255, 50, 50), width=1, style=line.style_dashed)
        tp1Line := line.new(bar_index, shortTP1, bar_index + 35, shortTP1, color=color.rgb(0, 200, 0), width=1, style=line.style_dashed)
        tp2Line := line.new(bar_index, shortTP2, bar_index + 35, shortTP2, color=color.rgb(0, 200, 0), width=1, style=line.style_dashed)
        tp3Line := line.new(bar_index, shortTP3, bar_index + 35, shortTP3, color=color.rgb(0, 200, 0), width=2, style=line.style_solid)
        tradeLabel := label.new(bar_index + 18, entryPrice, "بيع", style=label.style_label_center, color=color.rgb(255, 50, 50), textcolor=color.white, size=size.tiny)

// ╔══════════════════════════════════════════════════════════════╗
// ║              PART 16 - SMC VISUALIZATION (THROTTLED)       ║
// ╚══════════════════════════════════════════════════════════════╝

// Throttle variables - allow max 1 signal per 10 bars per type
var int lastBOSBar = 0
var int lastCHOCHBar = 0
var int lastSweepBar = 0
var int lastEqBar = 0

barsSinceBOS = bar_index - lastBOSBar
barsSinceCHOCH = bar_index - lastCHOCHBar
barsSinceSweep = bar_index - lastSweepBar
barsSinceEq = bar_index - lastEqBar

canDrawBOS = barsSinceBOS > 10 or barsSinceBOS < 0
canDrawCHOCH = barsSinceCHOCH > 10 or barsSinceCHOCH < 0
canDrawSweep = barsSinceSweep > 10 or barsSinceSweep < 0
canDrawEq = barsSinceEq > 10 or barsSinceEq < 0

if enableSmartMoney and showSMC
    if bullishBOS and canDrawBOS
        label.new(bar_index, low, "BOS ▲", style=label.style_label_up, color=color.rgb(0, 120, 255, 80), textcolor=color.white, size=size.tiny)
        lastBOSBar := bar_index
    if bearishBOS and canDrawBOS
        label.new(bar_index, high, "BOS ▼", style=label.style_label_down, color=color.rgb(0, 120, 255, 80), textcolor=color.white, size=size.tiny)
        lastBOSBar := bar_index
    if choChBull and canDrawCHOCH
        label.new(bar_index, low, "CHOCH ▲", style=label.style_label_up, color=color.rgb(255, 200, 0, 80), textcolor=color.black, size=size.tiny)
        lastCHOCHBar := bar_index
    if choChBear and canDrawCHOCH
        label.new(bar_index, high, "CHOCH ▼", style=label.style_label_down, color=color.rgb(255, 200, 0, 80), textcolor=color.black, size=size.tiny)
        lastCHOCHBar := bar_index
    if liquiditySweepLong and canDrawSweep
        label.new(bar_index, low, "سيولة ▲", style=label.style_label_up, color=color.rgb(255, 165, 0, 80), textcolor=color.white, size=size.tiny)
        lastSweepBar := bar_index
    if liquiditySweepShort and canDrawSweep
        label.new(bar_index, high, "سيولة ▼", style=label.style_label_down, color=color.rgb(255, 165, 0, 80), textcolor=color.white, size=size.tiny)
        lastSweepBar := bar_index
    if (equalHighs or equalLows) and canDrawEq
        if equalHighs
            label.new(bar_index, high, "=", style=label.style_label_down, color=color.gray, textcolor=color.white, size=size.tiny)
        if equalLows
            label.new(bar_index, low, "=", style=label.style_label_up, color=color.gray, textcolor=color.white, size=size.tiny)
        lastEqBar := bar_index

// ╔══════════════════════════════════════════════════════════════╗
// ║       PART 16B - ORDER BLOCKS (MAX 3, AUTO DELETE)         ║
// ╚══════════════════════════════════════════════════════════════╝

var box[] obBoxes = array.new_box(0)
var float[] obTop = array.new_float(0)
var float[] obBottom = array.new_float(0)
var bool[] obIsBull = array.new_bool(0)
var bool[] obMitigated = array.new_bool(0)

if enableSmartMoney and showSMC
    if bullishOB or bearishOB
        // #3: تصنيف OB مؤسسي حسب عدد التوافقات (Delta / Displacement / Liquidity / Absorption)
        // بدل مربع "OB" عام بدون تمييز جودة
        obConfluenceBull = (bullDisplacement ? 1 : 0) + (positiveDelta ? 1 : 0) + ((bullLiquidity or liquiditySweepLong or bullishLiquidityGrab) ? 1 : 0) + (absorptionBar ? 1 : 0)
        obConfluenceBear = (bearDisplacement ? 1 : 0) + (negativeDelta ? 1 : 0) + ((bearLiquidity or liquiditySweepShort or bearishLiquidityGrab) ? 1 : 0) + (absorptionBar ? 1 : 0)
        obConfluence = bullishOB ? obConfluenceBull : obConfluenceBear
        obGrade = obConfluence >= 3 ? "Institutional" : obConfluence == 2 ? "Strong" : obConfluence == 1 ? "Medium" : "Weak"

        obColor = bullishOB ? color.rgb(0, 200, 0, 80) : color.rgb(255, 50, 50, 80)
        obBorder = bullishOB ? color.green : color.red
        obText = "OB " + obGrade
        newBox = box.new(bar_index - 2, low, bar_index + 2, high, border_color=obBorder, bgcolor=obColor, border_width=1, text=obText)
        array.push(obBoxes, newBox)
        array.push(obTop, high)
        array.push(obBottom, low)
        array.push(obIsBull, bullishOB)
        array.push(obMitigated, false)

        // Delete oldest if more than 3
        if array.size(obBoxes) > 3
            oldBox = array.shift(obBoxes)
            box.delete(oldBox)
            array.shift(obTop)
            array.shift(obBottom)
            array.shift(obIsBull)
            array.shift(obMitigated)

// ╔══════════════════════════════════════════════════════════════╗
// ║       PART 16B2 - BREAKER & MITIGATION TRACKING (NEW)       ║
// ╚══════════════════════════════════════════════════════════════╝

if enableSmartMoney and showSMC and (showBreakerBlocks or showMitigationBlocks) and array.size(obBoxes) > 0
    for i = array.size(obBoxes) - 1 to 0
        obBoxI = array.get(obBoxes, i)
        topI = array.get(obTop, i)
        bottomI = array.get(obBottom, i)
        isBullI = array.get(obIsBull, i)
        mitigatedI = array.get(obMitigated, i)
        leftI = box.get_left(obBoxI)

        // Mitigation: price returns into the zone for the first time since formation
        if showMitigationBlocks and not mitigatedI and low <= topI and high >= bottomI
            box.set_border_style(obBoxI, line.style_dashed)
            box.set_bgcolor(obBoxI, color.new(color.gray, 85))
            array.set(obMitigated, i, true)

        // Breaker: bearish OB broken upward -> bullish breaker | bullish OB broken downward -> bearish breaker
        if showBreakerBlocks
            if isBullI and close < bottomI
                box.delete(obBoxI)
                box.new(leftI, topI, bar_index + 5, bottomI, border_color=color.red, bgcolor=color.new(color.red, 80), border_width=1, text="Breaker")
                array.remove(obBoxes, i)
                array.remove(obTop, i)
                array.remove(obBottom, i)
                array.remove(obIsBull, i)
                array.remove(obMitigated, i)
            else if not isBullI and close > topI
                box.delete(obBoxI)
                box.new(leftI, topI, bar_index + 5, bottomI, border_color=color.green, bgcolor=color.new(color.green, 80), border_width=1, text="Breaker")
                array.remove(obBoxes, i)
                array.remove(obTop, i)
                array.remove(obBottom, i)
                array.remove(obIsBull, i)
                array.remove(obMitigated, i)

// ╔══════════════════════════════════════════════════════════════╗
// ║       PART 16C - FVGs (MAX 2, AUTO DELETE)                 ║
// ╚══════════════════════════════════════════════════════════════╝

var box[] fvgBoxes = array.new_box(0)

if enableSmartMoney and showSMC
    if bullishFVG or bearishFVG
        // #4: تصنيف الفجوة حسب حجمها نسبة لـ ATR بدل نص "FVG" ثابت للجميع
        fvgGapSize = bullishFVG ? (low - high[2]) : (low[2] - high)
        fvgSizeATR = atrSmart > 0 ? fvgGapSize / atrSmart : 0
        fvgGrade = fvgSizeATR >= 1.5 ? "Institutional" : fvgSizeATR >= 1.0 ? "Strong" : fvgSizeATR >= 0.5 ? "Medium" : "Weak"

        fvgColor = bullishFVG ? color.rgb(0, 200, 0, 70) : color.rgb(255, 50, 50, 70)
        fvgBorder = bullishFVG ? color.green : color.red
        fvgText = "FVG " + fvgGrade
        box newFVG = na
        if bullishFVG
            newFVG := box.new(bar_index - 2, high[2], bar_index, low, border_color=fvgBorder, bgcolor=fvgColor, border_width=1, text=fvgText)
        else
            newFVG := box.new(bar_index - 2, low[2], bar_index, high, border_color=fvgBorder, bgcolor=fvgColor, border_width=1, text=fvgText)
        array.push(fvgBoxes, newFVG)

        // Delete oldest if more than 2
        if array.size(fvgBoxes) > 2
            oldFVG = array.shift(fvgBoxes)
            box.delete(oldFVG)

// ╔══════════════════════════════════════════════════════════════╗
// ║       PART 16D - SMC PRO VISUALIZATION (NEW, THROTTLED)     ║
// ╚══════════════════════════════════════════════════════════════╝

var int lastExtBOSBar = 0
var int lastIntBOSBar = 0
var int lastLiqGrabBar = 0
var int lastInducementBar = 0
var int lastRejectionBar = 0

canDrawExtBOS = (bar_index - lastExtBOSBar) > 10
canDrawIntBOS = (bar_index - lastIntBOSBar) > 10
canDrawLiqGrab = (bar_index - lastLiqGrabBar) > 10
canDrawInducement = (bar_index - lastInducementBar) > 10
canDrawRejection = (bar_index - lastRejectionBar) > 10

if enableSmartMoney and showSMC
    if (externalBullishBOS or externalCHoCHBull) and canDrawExtBOS
        extTxtBull = externalCHoCHBull ? "CHoCH خارجي ▲" : "BOS خارجي ▲"
        label.new(bar_index, low, extTxtBull, style=label.style_label_up, color=color.rgb(0, 80, 200, 40), textcolor=color.white, size=size.tiny)
        lastExtBOSBar := bar_index
    if (externalBearishBOS or externalCHoCHBear) and canDrawExtBOS
        extTxtBear = externalCHoCHBear ? "CHoCH خارجي ▼" : "BOS خارجي ▼"
        label.new(bar_index, high, extTxtBear, style=label.style_label_down, color=color.rgb(0, 80, 200, 40), textcolor=color.white, size=size.tiny)
        lastExtBOSBar := bar_index

    if (internalBullishBOS or internalCHoCHBull) and canDrawIntBOS
        intTxtBull = internalCHoCHBull ? "CHoCH داخلي ▲" : "BOS داخلي ▲"
        label.new(bar_index, low, intTxtBull, style=label.style_label_up, color=color.rgb(100, 100, 255, 60), textcolor=color.white, size=size.tiny)
        lastIntBOSBar := bar_index
    if (internalBearishBOS or internalCHoCHBear) and canDrawIntBOS
        intTxtBear = internalCHoCHBear ? "CHoCH داخلي ▼" : "BOS داخلي ▼"
        label.new(bar_index, high, intTxtBear, style=label.style_label_down, color=color.rgb(100, 100, 255, 60), textcolor=color.white, size=size.tiny)
        lastIntBOSBar := bar_index

    if bullishLiquidityGrab and canDrawLiqGrab
        label.new(bar_index, low, "LG ▲", style=label.style_label_up, color=color.rgb(255, 140, 0, 40), textcolor=color.white, size=size.tiny)
        lastLiqGrabBar := bar_index
    if bearishLiquidityGrab and canDrawLiqGrab
        label.new(bar_index, high, "LG ▼", style=label.style_label_down, color=color.rgb(255, 140, 0, 40), textcolor=color.white, size=size.tiny)
        lastLiqGrabBar := bar_index

    if inducementBull and canDrawInducement
        label.new(bar_index, low, "IDM ▲", style=label.style_label_up, color=color.rgb(180, 0, 180, 40), textcolor=color.white, size=size.tiny)
        lastInducementBar := bar_index
    if inducementBear and canDrawInducement
        label.new(bar_index, high, "IDM ▼", style=label.style_label_down, color=color.rgb(180, 0, 180, 40), textcolor=color.white, size=size.tiny)
        lastInducementBar := bar_index

    if rejectionBull and canDrawRejection
        label.new(bar_index, low, "RJ ▲", style=label.style_label_up, color=color.rgb(0, 150, 150, 40), textcolor=color.white, size=size.tiny)
        lastRejectionBar := bar_index
    if rejectionBear and canDrawRejection
        label.new(bar_index, high, "RJ ▼", style=label.style_label_down, color=color.rgb(0, 150, 150, 40), textcolor=color.white, size=size.tiny)
        lastRejectionBar := bar_index

// ╔══════════════════════════════════════════════════════════════╗
// ║       PART 16E - VOLUME PROFILE ENGINE (NEW: POC/VAH/VAL)   ║
// ║  يُحسب فقط عند barstate.islast (وليس كل شمعة) لتقليل استهلاك  ║
// ║  الموارد بشكل حقيقي بدل تكرار حلقة على 100+ شمعة كل تحديث     ║
// ╚══════════════════════════════════════════════════════════════╝

var line pocLine = na
var line vahLine = na
var line valLine = na
var label vpLabel = na

// FIX: استخراج ta.highest/ta.lowest لتُحسب كل شمعة (متطلب Pine للاتساق التاريخي)
// بينما تبقى الحلقة الثقيلة (for) وحدها محصورة داخل barstate.islast لتوفير الموارد
vpHigh = ta.highest(high, vpLookback)
vpLow = ta.lowest(low, vpLookback)

if showVolumeProfile and barstate.islast
    binSize = (vpHigh - vpLow) / vpBins

    if binSize > 0
        volBins = array.new_float(vpBins, 0.0)
        for i = 0 to vpLookback - 1
            idxRaw = math.floor((close[i] - vpLow) / binSize)
            idx = int(math.min(vpBins - 1, math.max(0, idxRaw)))
            array.set(volBins, idx, array.get(volBins, idx) + volume[i])

        totalVol = array.sum(volBins)
        pocIdx = array.indexof(volBins, array.max(volBins))

        if pocIdx >= 0 and totalVol > 0
            pocPrice = vpLow + (pocIdx + 0.5) * binSize
            targetVol = totalVol * (vpValueAreaPercent / 100)
            float vaVol = array.get(volBins, pocIdx)
            int upIdx = pocIdx
            int downIdx = pocIdx

            while vaVol < targetVol and (upIdx < vpBins - 1 or downIdx > 0)
                upVol = upIdx < vpBins - 1 ? array.get(volBins, upIdx + 1) : -1.0
                downVol = downIdx > 0 ? array.get(volBins, downIdx - 1) : -1.0
                if upVol >= downVol
                    upIdx := upIdx + 1
                    vaVol := vaVol + upVol
                else
                    downIdx := downIdx - 1
                    vaVol := vaVol + downVol

            vahPrice = vpLow + (upIdx + 1) * binSize
            valPrice = vpLow + downIdx * binSize

            line.delete(pocLine)
            line.delete(vahLine)
            line.delete(valLine)
            label.delete(vpLabel)

            pocLine := line.new(bar_index - vpLookback, pocPrice, bar_index + 10, pocPrice, color=color.yellow, width=2, style=line.style_solid)
            vahLine := line.new(bar_index - vpLookback, vahPrice, bar_index + 10, vahPrice, color=color.new(color.green, 40), width=1, style=line.style_dashed)
            valLine := line.new(bar_index - vpLookback, valPrice, bar_index + 10, valPrice, color=color.new(color.red, 40), width=1, style=line.style_dashed)
            vpLabel := label.new(bar_index + 10, pocPrice, "POC", style=label.style_label_left, color=color.yellow, textcolor=color.black, size=size.tiny)

// ╔══════════════════════════════════════════════════════════════╗
// ║       PART 16F - DYNAMIC LIQUIDITY MAP (NEW)                ║
// ║  خطان دائمان (Update in place) بدل إنشاء كائن جديد كل شمعة    ║
// ║  لأقرب مناطق سيولة، ويتغير لونهما عند سحب السيولة فعلياً       ║
// ╚══════════════════════════════════════════════════════════════╝

var line liqHighLine = na
var line liqLowLine = na

if showLiquidityMap
    if na(liqHighLine)
        liqHighLine := line.new(bar_index, highPool, bar_index + 20, highPool, color=color.rgb(255, 50, 50, 50), width=1, style=line.style_dotted)
        liqLowLine := line.new(bar_index, lowPool, bar_index + 20, lowPool, color=color.rgb(0, 200, 0, 50), width=1, style=line.style_dotted)
    else
        line.set_xy1(liqHighLine, bar_index - 1, highPool)
        line.set_xy2(liqHighLine, bar_index + 20, highPool)
        line.set_xy1(liqLowLine, bar_index - 1, lowPool)
        line.set_xy2(liqLowLine, bar_index + 20, lowPool)
        line.set_color(liqHighLine, bearishLiquidityGrab ? color.rgb(255, 50, 50, 10) : color.rgb(255, 50, 50, 50))
        line.set_color(liqLowLine, bullishLiquidityGrab ? color.rgb(0, 200, 0, 10) : color.rgb(0, 200, 0, 50))

// ╔══════════════════════════════════════════════════════════════╗
// ║              PART 17 - SIGNAL LABELS (MAX 1 PER TYPE)      ║
// ╚══════════════════════════════════════════════════════════════╝

var label entryLabel = na
var label exitLabel = na

if longEntry
    label.delete(entryLabel)
    entryLabel := label.new(bar_index, low, "شراء", style=label.style_label_up, color=color.rgb(0, 200, 0), textcolor=color.white, size=size.small)

if shortEntry
    label.delete(entryLabel)
    entryLabel := label.new(bar_index, high, "بيع", style=label.style_label_down, color=color.rgb(255, 50, 50), textcolor=color.white, size=size.small)

if smartExitLong or smartExitShort or partialExitLong or partialExitShort
    label.delete(exitLabel)
    exitLabel := label.new(bar_index, smartExitLong or partialExitLong ? high : low, "خروج", style=smartExitLong or partialExitLong ? label.style_label_down : label.style_label_up, color=color.rgb(255, 165, 0), textcolor=color.white, size=size.small)

// ╔══════════════════════════════════════════════════════════════╗
// ║              PART 18 - DASHBOARD (REDUCED 60%)             ║
// ╚══════════════════════════════════════════════════════════════╝

// --- Colors ---
signalColorDB = fusionDecision == "BUY" ? color.rgb(0, 200, 0) : fusionDecision == "SELL" ? color.rgb(255, 50, 50) : color.rgb(255, 200, 0)
confidenceColorDB = calibratedConfidence >= 80 ? color.rgb(0, 200, 0) : calibratedConfidence >= 60 ? color.rgb(255, 200, 0) : color.rgb(255, 50, 50)
gradeColorDB = calibratedConfidence >= 90 ? color.rgb(0, 200, 0) : calibratedConfidence >= 70 ? color.rgb(0, 120, 255) : calibratedConfidence >= 50 ? color.rgb(255, 200, 0) : color.rgb(255, 50, 50)
trendColorDB = bullTrend ? color.rgb(0, 200, 0) : bearTrend ? color.rgb(255, 50, 50) : color.rgb(128, 128, 128)
sessionColorDB = sessionName == "لندن" ? color.rgb(0, 120, 255) : sessionName == "نيويورك" ? color.rgb(0, 200, 0) : sessionName == "آسيا" ? color.rgb(255, 200, 0) : color.rgb(128, 128, 128)
probColorDB = winProbabilityCalibrated >= 70 ? color.rgb(0, 200, 0) : winProbabilityCalibrated >= 50 ? color.rgb(255, 200, 0) : color.rgb(255, 50, 50)
regimeColorDB = marketRegime == "Trending" ? color.rgb(0, 200, 0) : marketRegime == "Expansion" ? color.rgb(0, 120, 255) : marketRegime == "Distribution" ? color.rgb(255, 50, 50) : marketRegime == "Accumulation" ? color.rgb(0, 150, 150) : color.rgb(128, 128, 128)
winRateColorDB = na(realWinRate) ? color.rgb(80, 80, 80) : realWinRate >= 50 ? color.rgb(0, 200, 0) : color.rgb(255, 50, 50)
expectancyColorDB = na(realExpectancyR) ? color.rgb(80, 80, 80) : realExpectancyR >= 0 ? color.rgb(0, 200, 0) : color.rgb(255, 50, 50)

// --- Dashboard Table (13 rows) ---
var table dashTable = table.new(position.top_right, 2, 13, border_width=0, frame_width=0, bgcolor=color.rgb(10, 10, 15, 85))

if barstate.islast and showDashboard
    // Row 0 - Title
    table.cell(dashTable, 0, 0, "AQE V10", text_color=color.white, bgcolor=color.rgb(0, 80, 200), text_size=size.small)
    table.cell(dashTable, 1, 0, "PRO", text_color=color.white, bgcolor=color.rgb(0, 80, 200), text_size=size.small)

    // Row 1 - القرار
    table.cell(dashTable, 0, 1, "القرار", text_color=color.rgb(160, 160, 160), bgcolor=na, text_size=size.tiny)
    table.cell(dashTable, 1, 1, aiDecisionArabic, text_color=color.white, bgcolor=signalColorDB, text_size=size.tiny)

    // Row 2 - الاحتمالية (Probability Engine - حقيقي إحصائياً بعد توفر عينة كافية)
    table.cell(dashTable, 0, 2, "الاحتمالية", text_color=color.rgb(160, 160, 160), bgcolor=na, text_size=size.tiny)
    table.cell(dashTable, 1, 2, str.tostring(winProbabilityCalibrated, "#") + "%", text_color=color.white, bgcolor=probColorDB, text_size=size.tiny)

    // Row 3 - الثقة (معايرة)
    table.cell(dashTable, 0, 3, "الثقة", text_color=color.rgb(160, 160, 160), bgcolor=na, text_size=size.tiny)
    table.cell(dashTable, 1, 3, str.tostring(calibratedConfidence, "#") + "%", text_color=color.white, bgcolor=confidenceColorDB, text_size=size.tiny)

    // Row 4 - الدرجة
    table.cell(dashTable, 0, 4, "الدرجة", text_color=color.rgb(160, 160, 160), bgcolor=na, text_size=size.tiny)
    table.cell(dashTable, 1, 4, aiGrade, text_color=color.white, bgcolor=gradeColorDB, text_size=size.tiny)

    // Row 5 - النظام السوقي (Market Regime)
    table.cell(dashTable, 0, 5, "النظام", text_color=color.rgb(160, 160, 160), bgcolor=na, text_size=size.tiny)
    table.cell(dashTable, 1, 5, marketRegimeArabic, text_color=color.white, bgcolor=regimeColorDB, text_size=size.tiny)

    // Row 6 - اتجاه السوق
    table.cell(dashTable, 0, 6, "الاتجاه", text_color=color.rgb(160, 160, 160), bgcolor=na, text_size=size.tiny)
    marketText = bullTrend ? "صاعد" : bearTrend ? "هابط" : "عرضي"
    table.cell(dashTable, 1, 6, marketText, text_color=color.white, bgcolor=trendColorDB, text_size=size.tiny)

    // Row 7 - قوة الاتجاه
    table.cell(dashTable, 0, 7, "القوة", text_color=color.rgb(160, 160, 160), bgcolor=na, text_size=size.tiny)
    table.cell(dashTable, 1, 7, str.tostring(trendStrengthPercent, "#") + "%", text_color=color.white, bgcolor=trendStrong ? color.rgb(0, 200, 0) : color.rgb(255, 200, 0), text_size=size.tiny)

    // Row 8 - معدل الفوز الحقيقي (Real Win Rate)
    table.cell(dashTable, 0, 8, "معدل الفوز", text_color=color.rgb(160, 160, 160), bgcolor=na, text_size=size.tiny)
    winRateText = na(realWinRate) ? "قيد التجميع" : str.tostring(realWinRate, "#") + "% (" + str.tostring(statTotalTrades, "#") + ")"
    table.cell(dashTable, 1, 8, winRateText, text_color=color.white, bgcolor=winRateColorDB, text_size=size.tiny)

    // Row 9 - التوقع (Trade Expectancy بوحدة R)
    table.cell(dashTable, 0, 9, "التوقع R", text_color=color.rgb(160, 160, 160), bgcolor=na, text_size=size.tiny)
    expectancyText = na(realExpectancyR) ? "-" : str.tostring(realExpectancyR, "#.##") + "R"
    table.cell(dashTable, 1, 9, expectancyText, text_color=color.white, bgcolor=expectancyColorDB, text_size=size.tiny)

    // Row 10 - الجلسة
    table.cell(dashTable, 0, 10, "الجلسة", text_color=color.rgb(160, 160, 160), bgcolor=na, text_size=size.tiny)
    table.cell(dashTable, 1, 10, sessionName, text_color=color.white, bgcolor=sessionColorDB, text_size=size.tiny)

    // Row 11 - الهدف (يستخدم مستوى الصفقة الثابت طوال مدتها)
    table.cell(dashTable, 0, 11, "الهدف", text_color=color.rgb(160, 160, 160), bgcolor=na, text_size=size.tiny)
    tp1Text = inLongPosition ? str.tostring(tradeTP1, "#.##") : inShortPosition ? str.tostring(tradeTP1, "#.##") : "-"
    table.cell(dashTable, 1, 11, tp1Text, text_color=color.white, bgcolor=color.rgb(0, 150, 0, 40), text_size=size.tiny)

    // Row 12 - الوقف (يستخدم مستوى الصفقة الثابت طوال مدتها)
    table.cell(dashTable, 0, 12, "الوقف", text_color=color.rgb(160, 160, 160), bgcolor=na, text_size=size.tiny)
    slText = inLongPosition ? str.tostring(tradeSL, "#.##") : inShortPosition ? str.tostring(tradeSL, "#.##") : "-"
    table.cell(dashTable, 1, 12, slText, text_color=color.white, bgcolor=color.rgb(200, 0, 0, 40), text_size=size.tiny)

// ╔══════════════════════════════════════════════════════════════╗
// ║              PART 19 - ALERTS SYSTEM (UNCHANGED)           ║
// ╚══════════════════════════════════════════════════════════════╝

alertcondition(longEntry and alertBuy, "AQE V10 - شراء", "إشارة شراء AQE V10")
alertcondition(shortEntry and alertSell, "AQE V10 - بيع", "إشارة بيع AQE V10")

alertcondition(smartExitLong and alertExit, "AQE V10 - خروج شراء", "إشارة خروج شراء")
alertcondition(smartExitShort and alertExit, "AQE V10 - خروج بيع", "إشارة خروج بيع")
alertcondition(partialExitLong and alertExit, "AQE V10 - جني ربح شراء", "جني ربح جزئي شراء")
alertcondition(partialExitShort and alertExit, "AQE V10 - جني ربح بيع", "جني ربح جزئي بيع")

alertcondition(bullishBOS and alertSMC, "AQE V10 - كسر هيكل صاعد", "كسر هيكل صاعد")
alertcondition(bearishBOS and alertSMC, "AQE V10 - كسر هيكل هابط", "كسر هيكل هابط")
alertcondition(choChBull and alertSMC, "AQE V10 - تغيير اتجاه صاعد", "تغيير اتجاه صاعد")
alertcondition(choChBear and alertSMC, "AQE V10 - تغيير اتجاه هابط", "تغيير اتجاه هابط")
alertcondition(bullishFVG and alertSMC, "AQE V10 - فجوة صاعدة", "فجوة قيمة عادلة صاعدة")
alertcondition(bearishFVG and alertSMC, "AQE V10 - فجوة هابطة", "فجوة قيمة عادلة هابطة")
alertcondition(liquiditySweepLong and alertSMC, "AQE V10 - سحب سيولة صاعد", "سحب سيولة صاعد")
alertcondition(liquiditySweepShort and alertSMC, "AQE V10 - سحب سيولة هابط", "سحب سيولة هابط")

alertcondition(externalBullishBOS and alertSMC, "AQE V10 - BOS خارجي صاعد", "كسر هيكل خارجي صاعد (Major)")
alertcondition(externalBearishBOS and alertSMC, "AQE V10 - BOS خارجي هابط", "كسر هيكل خارجي هابط (Major)")
alertcondition(externalCHoCHBull and alertSMC, "AQE V10 - CHoCH خارجي صاعد", "تغيير هيكل خارجي صاعد")
alertcondition(externalCHoCHBear and alertSMC, "AQE V10 - CHoCH خارجي هابط", "تغيير هيكل خارجي هابط")
alertcondition(bullishLiquidityGrab and alertSMC, "AQE V10 - سحب سيولة حقيقي صاعد", "Liquidity Grab صاعد")
alertcondition(bearishLiquidityGrab and alertSMC, "AQE V10 - سحب سيولة حقيقي هابط", "Liquidity Grab هابط")
alertcondition(inducementBull and alertSMC, "AQE V10 - إغراء صاعد", "Inducement صاعد قبل استمرار الاتجاه")
alertcondition(inducementBear and alertSMC, "AQE V10 - إغراء هابط", "Inducement هابط قبل استمرار الاتجاه")

alertcondition(bullTrend and not bullTrend[1] and alertTrend, "AQE V10 - تغير اتجاه صاعد", "تغير الاتجاه إلى صاعد")
alertcondition(bearTrend and not bearTrend[1] and alertTrend, "AQE V10 - تغير اتجاه هابط", "تغير الاتجاه إلى هابط")

alertcondition(longEntry and fusionScore >= 90 and alertBuy, "AQE V10 - شراء قوي", "إشارة شراء قوية AQE V10")
alertcondition(shortEntry and fusionScore >= 90 and alertSell, "AQE V10 - بيع قوي", "إشارة بيع قوية AQE V10")

// ╔══════════════════════════════════════════════════════════════╗
// ║              PART 20 - FUSION SCORE (SEPARATE PANE)        ║
// ╚══════════════════════════════════════════════════════════════╝

// Score moved to separate pane using overlay=false indicator
// This is now plotted in its own pane below the main chart
scoreColor = finalAIScore >= 80 ? color.rgb(0, 200, 0) : finalAIScore >= 60 ? color.rgb(255, 200, 0) : color.rgb(255, 50, 50)
plot(finalAIScore, "AQE Fusion Score", color=scoreColor, linewidth=2, style=plot.style_columns, display=display.none)

