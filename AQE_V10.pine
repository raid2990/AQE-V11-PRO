indicator(
     "AQE V10.0 PRO | Fusion Intelligence",
     overlay=true,
     max_labels_count=500,
     max_boxes_count=500,
     max_lines_count=500,
     max_bars_back=500)

// ╔══════════════════════════════════════════════════════════════╗
// ║                    PART 0 - INPUT GROUPS                   ║
// ╚══════════════════════════════════════════════════════════════╝

// --- General Settings ---
generalGroup = "⚙️ الإعدادات العامة"
minimumScore = input.int(80, "الحد الأدنى للثقة", minval=50, maxval=100, group=generalGroup)
showTradeMap = input.bool(true, "إظهار خريطة الصفقة", group=generalGroup)
showCharts = input.bool(true, "تفعيل خلفيات الرسم البياني", group=generalGroup)
enableHeatMap = input.bool(true, "تفعيل خريطة الحرارة", group=generalGroup)

// --- AI Settings ---
aiGroup = "🤖 الذكاء الاصطناعي"
aiEnabled = input.bool(true, "تفعيل محرك الذكاء الاصطناعي", group=aiGroup)
aiSensitivity = input.int(70, "حساسية الذكاء الاصطناعي", minval=50, maxval=100, group=aiGroup)
aiMinConfidence = input.int(65, "الحد الأدنى لثقة الذكاء الاصطناعي", minval=50, maxval=90, group=aiGroup)

// --- Risk Settings ---
riskGroup = "📊 إدارة المخاطر"
accountSize = input.float(10000, "💰 حجم الحساب", group=riskGroup)
riskPercent = input.float(1.0, "📉 نسبة المخاطرة %", step=0.1, group=riskGroup)
riskMultiplier = input.float(1.5, "📏 مضاعف ATR للوقف", step=0.1, group=riskGroup)
enableBreakeven = input.bool(true, "🔄 تفعيل نقطة التعادل", group=riskGroup)
breakevenTrigger = input.float(1.0, "🎯 هدف التعادل (R)", step=0.1, group=riskGroup)
enablePartialExit = input.bool(true, "📤 تفعيل جني أرباح جزئي", group=riskGroup)
partialExitPercent = input.float(50, "نسبة الجني الجزئي %", step=10, group=riskGroup)

// --- Dashboard Settings ---
dashboardGroup = "📋 لوحة التحكم"
showDashboard = input.bool(true, "إظهار لوحة التحكم الاحترافية", group=dashboardGroup)
dashboardPosition = input.string("top_right", "موقع لوحة التحكم", options=["top_right", "top_left", "bottom_right", "bottom_left"], group=dashboardGroup)

// --- MTF Settings ---
mtfGroup = "🕐 الإطارات الزمنية المتعددة"
enableMTF = input.bool(true, "تفعيل تحليل الإطارات المتعددة", group=mtfGroup)
mtfMinAlignment = input.int(8, "الحد الأدنى لتوافق الإطارات", minval=1, maxval=16, group=mtfGroup)

// --- Smart Money Settings ---
smartMoneyGroup = "💎 مفاهيم المؤسسات"
enableSmartMoney = input.bool(true, "تفعيل تحليل المؤسسات", group=smartMoneyGroup)
showSMC = input.bool(true, "إظهار إشارات المؤسسات", group=smartMoneyGroup)
smcSensitivity = input.int(3, "حساسية إشارات المؤسسات", minval=1, maxval=5, group=smartMoneyGroup)

// --- Volume Settings ---
volumeGroup = "📈 تحليل الحجم"
enableVolumeAnalysis = input.bool(true, "تفعيل تحليل الحجم", group=volumeGroup)
volumeThreshold = input.float(1.5, "عتبة الحجم المؤسسي", step=0.1, group=volumeGroup)

// --- Trend Settings ---
trendGroup = "📉 محرك الاتجاه"
enableADX = input.bool(true, "تفعيل ADX", group=trendGroup)
adxThreshold = input.int(25, "عتبة ADX", minval=15, maxval=50, group=trendGroup)

// --- Session Settings ---
sessionGroup = "🌍 جلسات التداول"
showSessions = input.bool(true, "إظهار الجلسات", group=sessionGroup)

// --- Trailing Settings ---
trailGroup = "🛡️ الحماية المتحركة"
enableTrail = input.bool(true, "تفعيل الوقف المتحرك", group=trailGroup)
trailATR = input.float(1.2, "مضاعف ATR المتحرك", step=0.1, group=trailGroup)
trailActivation = input.float(0.5, "تفعيل بعد (R)", step=0.1, group=trailGroup)

// --- Smart Exit Settings ---
exitGroup = "🚪 الخروج الذكي"
useSmartExit = input.bool(true, "تفعيل الخروج الذكي", group=exitGroup)
exitRSI = input.int(45, "مستوى RSI للخروج", group=exitGroup)

// --- Alert Settings ---
alertGroup = "🔔 التنبيهات"
alertBuy = input.bool(true, "تنبيه شراء", group=alertGroup)
alertSell = input.bool(true, "تنبيه بيع", group=alertGroup)
alertExit = input.bool(true, "تنبيه خروج", group=alertGroup)
alertSMC = input.bool(true, "تنبيه إشارات المؤسسات", group=alertGroup)
alertTrend = input.bool(true, "تنبيه تغير الاتجاه", group=alertGroup)

// ╔══════════════════════════════════════════════════════════════╗
// ║              PART 1 - GLOBAL CALCULATIONS                  ║
// ║              (Single Computation Architecture)             ║
// ║              ALL ta.* CALLS IN GLOBAL SCOPE               ║
// ╚══════════════════════════════════════════════════════════════╝

// --- Core Technical Indicators (Computed Once) ---
atrSmart = ta.atr(14)
ema50 = ta.ema(close, 50)
ema200 = ta.ema(close, 200)
rsiValue = ta.rsi(close, 14)
avgVolume = ta.sma(volume, 20)
highPool = ta.highest(high, 20)
lowPool = ta.lowest(low, 20)
vwapValue = ta.vwap(close)

// --- ta.change Calls (Global Scope - Required by Pine Script V6) ---
changeHigh = ta.change(high)
changeLow = ta.change(low)

// --- ADX Suite (All ta.* calls in global scope) ---
adxLength = 14
trueRangeVal = ta.tr(true)

plusDM = changeHigh > changeLow and changeHigh > 0 ? changeHigh : 0
minusDM = changeLow > changeHigh and changeLow > 0 ? changeLow : 0

smoothedTR = ta.rma(trueRangeVal, adxLength)
smoothedPlusDM = ta.rma(plusDM, adxLength)
smoothedMinusDM = ta.rma(minusDM, adxLength)

diPlus = (smoothedPlusDM / smoothedTR) * 100
diMinus = (smoothedMinusDM / smoothedTR) * 100

dxValue = math.abs(diPlus - diMinus) / (diPlus + diMinus) * 100
adxValue = ta.rma(dxValue, adxLength)

// --- ta.rising / ta.falling Calls (Global Scope) ---
risingClose10 = ta.rising(close, 10)
risingATR3 = ta.rising(atrSmart, 3)
fallingClose10 = ta.falling(close, 10)

risingADX5 = ta.rising(adxValue, 5)
fallingADX5 = ta.falling(adxValue, 5)

risingATR5 = ta.rising(atrSmart, 5)
fallingATR5 = ta.falling(atrSmart, 5)

fallingVolume3 = ta.falling(volume, 3)
fallingClose2 = ta.falling(close, 2)

// --- ta.sma Calls (Global Scope) ---
smaHigh20 = ta.sma(high, 20)
smaLow20 = ta.sma(low, 20)
smaClose20 = ta.sma(close, 20)
smaATR20 = ta.sma(atrSmart, 20)

// --- Derived Calculations ---
emaSlope = (ema50 - ema50[5]) / ema50[5] * 100
relativeVolume = volume / avgVolume

// --- Fixed Missing Variables ---
vwapDiff = close - vwapValue
vwapDiffPercent = math.abs(vwapDiff) / vwapValue * 100
vwapFar = vwapDiffPercent > 1.5

atrTrendUp = risingClose10 and risingATR3
atrTrendDown = fallingClose10 and risingATR3

// ╔══════════════════════════════════════════════════════════════╗
// ║              PART 2 - SESSION ENGINE (FIXED)               ║
// ╚══════════════════════════════════════════════════════════════╝

// --- Session Detection Function ---
getSession(h) =>
    if h >= 1 and h < 9
        "آسيا"
    else if h >= 8 and h < 17
        "لندن"
    else if h >= 13 and h < 22
        "نيويورك"
    else
        "سيدني"

// Fixed: Using syminfo.timezone for proper timezone handling
hourNow = hour(time(timeframe.period, syminfo.timezone))
sessionName = getSession(hourNow)
isKillZone = (hourNow >= 7 and hourNow < 10) or (hourNow >= 13 and hourNow < 16)
sessionActive = true

// ╔══════════════════════════════════════════════════════════════╗
// ║              PART 3 - TREND ENGINE V10                     ║
// ╚══════════════════════════════════════════════════════════════╝

// --- Basic Trend ---
bullTrend = ema50 > ema200
bearTrend = ema50 < ema200
neutralTrend = not bullTrend and not bearTrend

// --- ADX Analysis ---
trendStrong = adxValue > adxThreshold
trendVeryStrong = adxValue > 40
trendWeak = adxValue <= adxThreshold
trendStrengthPercent = math.min(100, math.round(adxValue * 2))

// --- Trend Direction ---
bullDI = diPlus > diMinus
bearDI = diMinus > diPlus

// --- EMA Slope Analysis ---
emaRising = emaSlope > 0.1
emaFalling = emaSlope < -0.1
emaFlat = math.abs(emaSlope) <= 0.1

// --- Trend Dynamics ---
trendWeakening = fallingADX5 and trendStrong
trendAcceleration = risingADX5 and adxValue > 20
trendMomentum = emaSlope * adxValue / 20

// --- Market Phase Detection Function ---
getMarketPhase() =>
    if trendVeryStrong and bullTrend
        "صاعد بقوة"
    else if trendVeryStrong and bearTrend
        "هابط بقوة"
    else if trendStrong and bullTrend
        "صاعد"
    else if trendStrong and bearTrend
        "هابط"
    else if trendWeakening and bullTrend
        "ضعف الصعود"
    else if trendWeakening and bearTrend
        "ضعف الهبوط"
    else if trendAcceleration and bullDI
        "تسارع صاعد"
    else if trendAcceleration and bearDI
        "تسارع هابط"
    else
        "عرضي"

marketPhase = getMarketPhase()

// ╔══════════════════════════════════════════════════════════════╗
// ║              PART 4 - LIQUIDITY ENGINE                     ║
// ╚══════════════════════════════════════════════════════════════╝

bullLiquidity = low < lowPool[1] and close > open
bearLiquidity = high > highPool[1] and close < open
liquiditySweepLong = low < lowPool[1] and close > highPool[1]
liquiditySweepShort = high > highPool[1] and close < lowPool[1]

// ╔══════════════════════════════════════════════════════════════╗
// ║              PART 5 - SMART MONEY ENGINE V10               ║
// ╚══════════════════════════════════════════════════════════════╝

// --- Displacement ---
bullDisplacement = close > open and (close - open) > atrSmart * 0.8
bearDisplacement = close < open and (open - close) > atrSmart * 0.8

// --- Swing Detection Function ---
detectSwingHigh() =>
    high > high[1] and high > high[2] and high[1] >= high[3] and high[2] >= high[4]

detectSwingLow() =>
    low < low[1] and low < low[2] and low[1] <= low[3] and low[2] <= low[4]

swingHigh = detectSwingHigh()
swingLow = detectSwingLow()

// --- Break of Structure (BOS) ---
var float lastSwingHigh = na
var float lastSwingLow = na
var int swingHighBar = na
var int swingLowBar = na

if swingHigh
    lastSwingHigh := high
    swingHighBar := bar_index

if swingLow
    lastSwingLow := low
    swingLowBar := bar_index

bullishBOS = close > lastSwingHigh and not na(lastSwingHigh) and bar_index > swingHighBar
bearishBOS = close < lastSwingLow and not na(lastSwingLow) and bar_index > swingLowBar

// --- Change of Character (CHOCH) ---
choChBull = close > high[smcSensitivity] and open < low[smcSensitivity]
choChBear = close < low[smcSensitivity] and open > high[smcSensitivity]

// --- Order Blocks (Enhanced) ---
bullishOB = low < low[1] and close > open and close > (high[1] + low[1]) / 2 and volume > avgVolume
bearishOB = high > high[1] and close < open and close < (high[1] + low[1]) / 2 and volume > avgVolume

// --- Fair Value Gap (FVG) ---
bullishFVG = low > high[2] and close > open and volume > avgVolume
bearishFVG = high < low[2] and close < open and volume > avgVolume

// --- Premium / Discount Zones ---
rangeHigh50 = ta.highest(high, 50)
rangeLow50 = ta.lowest(low, 50)
rangeMid = (rangeHigh50 + rangeLow50) / 2
inPremiumZone = close > rangeHigh50 * 0.618 + rangeLow50 * 0.382
inDiscountZone = close < rangeHigh50 * 0.382 + rangeLow50 * 0.618
inEquilibrium = not inPremiumZone and not inDiscountZone

// --- Equal Highs / Lows ---
equalHighs = math.abs(high - high[1]) < atrSmart * 0.15 and high > smaHigh20
equalLows = math.abs(low - low[1]) < atrSmart * 0.15 and low < smaLow20

// ╔══════════════════════════════════════════════════════════════╗
// ║              PART 6 - VOLUME ENGINE V10                    ║
// ╚══════════════════════════════════════════════════════════════╝

// --- Volume Classifications ---
institutionalVolume = volume > avgVolume * volumeThreshold
volumeSpike = volume > avgVolume * 2.5
weakVolume = volume < avgVolume * 0.5
strongVolume = volume > avgVolume * 1.8

// --- True Delta Calculation ---
bodySize = math.abs(close - open)
upperWick = high - math.max(close, open)
lowerWick = math.min(close, open) - low

volumeDelta = close > open ? volume * (bodySize + upperWick) / math.max(high - low, 0.0001) : -volume * (bodySize + lowerWick) / math.max(high - low, 0.0001)
volumeDeltaSmooth = ta.sma(volumeDelta, 5)
positiveDelta = volumeDeltaSmooth > 0
negativeDelta = volumeDeltaSmooth < 0

// --- Buying/Selling Pressure ---
buyingPressure = close > open ? volume * (close - open) / math.max(high - low, 0.0001) : 0
sellingPressure = close < open ? volume * (open - close) / math.max(high - low, 0.0001) : 0
netPressure = ta.sma(buyingPressure - sellingPressure, 10)
buyVolumeDominant = netPressure > 0
sellVolumeDominant = netPressure < 0

// --- Volume Climax & Exhaustion ---
volumeClimax = volume > avgVolume * 3.0 and (close > smaClose20 or close < smaClose20)
volumeExhaustion = volume > avgVolume * 2.0 and fallingVolume3 and fallingClose2

// --- Smart Volume ---
smartVolumeBuy = volume > avgVolume * 1.3 and close > open and rsiValue > 50
smartVolumeSell = volume > avgVolume * 1.3 and close < open and rsiValue < 50

// ╔══════════════════════════════════════════════════════════════╗
// ║              PART 7 - VOLATILITY ENGINE                    ║
// ╚══════════════════════════════════════════════════════════════╝

atrRising = risingATR5
atrFalling = fallingATR5
volatilityExpanding = atrSmart > smaATR20 * 1.2
volatilityContracting = atrSmart < smaATR20 * 0.8
volatilityNormal = not volatilityExpanding and not volatilityContracting

// ╔══════════════════════════════════════════════════════════════╗
// ║              PART 8 - FUSION SCORE ENGINE V10              ║
// ║              (Professional Weighted System - 100 Points)   ║
// ╚══════════════════════════════════════════════════════════════╝

// --- Fusion Component Function ---
calcComponent(condition, weight) =>
    condition ? weight : 0

// --- Initialize Scores ---
float buyScore = 0.0
float sellScore = 0.0

// --- 1. Trend Component (Max 18 pts) ---
buyScore += calcComponent(bullTrend, 7)
buyScore += calcComponent(bullDI, 4)
buyScore += calcComponent(emaRising, 4)
buyScore += calcComponent(trendStrong and bullTrend, 3)

sellScore += calcComponent(bearTrend, 7)
sellScore += calcComponent(bearDI, 4)
sellScore += calcComponent(emaFalling, 4)
sellScore += calcComponent(trendStrong and bearTrend, 3)

// --- 2. Momentum Component (Max 12 pts) ---
buyScore += calcComponent(rsiValue > 60, 6)
buyScore += calcComponent(rsiValue > 50 and rsiValue <= 60, 3)
buyScore += calcComponent(trendAcceleration, 3)

sellScore += calcComponent(rsiValue < 40, 6)
sellScore += calcComponent(rsiValue < 50 and rsiValue >= 40, 3)
sellScore += calcComponent(trendAcceleration and bearTrend, 3)

// --- 3. Volume Component (Max 15 pts) ---
buyScore += calcComponent(institutionalVolume and close > open, 5)
buyScore += calcComponent(buyVolumeDominant, 4)
buyScore += calcComponent(positiveDelta, 3)
buyScore += calcComponent(smartVolumeBuy, 3)

sellScore += calcComponent(institutionalVolume and close < open, 5)
sellScore += calcComponent(sellVolumeDominant, 4)
sellScore += calcComponent(negativeDelta, 3)
sellScore += calcComponent(smartVolumeSell, 3)

// --- 4. Liquidity Component (Max 12 pts) ---
buyScore += calcComponent(bullLiquidity, 6)
buyScore += calcComponent(liquiditySweepLong, 6)

sellScore += calcComponent(bearLiquidity, 6)
sellScore += calcComponent(liquiditySweepShort, 6)

// --- 5. Displacement Component (Max 10 pts) ---
buyScore += calcComponent(bullDisplacement, 10)
sellScore += calcComponent(bearDisplacement, 10)

// --- 6. VWAP Component (Max 8 pts) ---
buyScore += calcComponent(close > vwapValue, 4)
buyScore += calcComponent(close > vwapValue and vwapFar, 4)

sellScore += calcComponent(close < vwapValue, 4)
sellScore += calcComponent(close < vwapValue and vwapFar, 4)

// --- 7. ATR Trend Component (Max 5 pts) ---
buyScore += calcComponent(atrTrendUp, 5)
sellScore += calcComponent(atrTrendDown, 5)

// --- 8. ADX Component (Max 5 pts) ---
buyScore += calcComponent(adxValue > 25 and bullDI, 5)
sellScore += calcComponent(adxValue > 25 and bearDI, 5)

// --- 9. Volatility Component (Max 5 pts) ---
buyScore += calcComponent(volatilityContracting and close > ema50, 3)
buyScore += calcComponent(volatilityExpanding and bullTrend, 2)

sellScore += calcComponent(volatilityContracting and close < ema50, 3)
sellScore += calcComponent(volatilityExpanding and bearTrend, 2)

// --- 10. Market Structure Component (Max 5 pts) ---
buyScore += calcComponent(inDiscountZone, 3)
buyScore += calcComponent(bullishBOS, 2)

sellScore += calcComponent(inPremiumZone, 3)
sellScore += calcComponent(bearishBOS, 2)

// --- 11. Volume Quality Bonus (Max 5 pts) ---
buyScore += calcComponent(volumeSpike and close > open, 2)
buyScore += calcComponent(strongVolume and not volumeExhaustion, 3)

sellScore += calcComponent(volumeSpike and close < open, 2)
sellScore += calcComponent(strongVolume and not volumeExhaustion, 3)

// --- Ensure 100 Point Maximum ---
buyScore := math.min(buyScore, 100)
sellScore := math.min(sellScore, 100)

// --- Fusion Score Base ---
fusionScoreBase = math.max(buyScore, sellScore)

// ╔══════════════════════════════════════════════════════════════╗
// ║              PART 9 - MTF INTELLIGENCE ENGINE V10          ║
// ╚══════════════════════════════════════════════════════════════╝

// --- MTF Request Functions ---
getMTF_EMA(tf, length) =>
    request.security(syminfo.tickerid, tf, ta.ema(close, length))

getMTF_RSI(tf, length) =>
    request.security(syminfo.tickerid, tf, ta.rsi(close, length))

getMTF_Volume(tf) =>
    [request.security(syminfo.tickerid, tf, volume), request.security(syminfo.tickerid, tf, ta.sma(volume, 20))]

// --- MTF EMA Data ---
ema50_5m = getMTF_EMA("5", 50)
ema200_5m = getMTF_EMA("5", 200)
ema50_15m = getMTF_EMA("15", 50)
ema200_15m = getMTF_EMA("15", 200)
ema50_1h = getMTF_EMA("60", 50)
ema200_1h = getMTF_EMA("60", 200)
ema50_4h = getMTF_EMA("240", 50)
ema200_4h = getMTF_EMA("240", 200)

// --- MTF RSI Data ---
rsi_5m = getMTF_RSI("5", 14)
rsi_15m = getMTF_RSI("15", 14)
rsi_1h = getMTF_RSI("60", 14)
rsi_4h = getMTF_RSI("240", 14)

// --- MTF Volume Data ---
[vol_5m, avgVol_5m] = getMTF_Volume("5")
[vol_15m, avgVol_15m] = getMTF_Volume("15")
[vol_1h, avgVol_1h] = getMTF_Volume("60")
[vol_4h, avgVol_4h] = getMTF_Volume("240")

// --- MTF Trend States ---
bull_5m = ema50_5m > ema200_5m
bull_15m = ema50_15m > ema200_15m
bull_1h = ema50_1h > ema200_1h
bull_4h = ema50_4h > ema200_4h

bear_5m = ema50_5m < ema200_5m
bear_15m = ema50_15m < ema200_15m
bear_1h = ema50_1h < ema200_1h
bear_4h = ema50_4h < ema200_4h

// --- MTF RSI Alignment ---
rsiBull_5m = rsi_5m > 50
rsiBull_15m = rsi_15m > 50
rsiBull_1h = rsi_1h > 50
rsiBull_4h = rsi_4h > 50

rsiBear_5m = rsi_5m < 50
rsiBear_15m = rsi_15m < 50
rsiBear_1h = rsi_1h < 50
rsiBear_4h = rsi_4h < 50

// --- MTF Volume Alignment ---
volAbove_5m = vol_5m > avgVol_5m
volAbove_15m = vol_15m > avgVol_15m
volAbove_1h = vol_1h > avgVol_1h
volAbove_4h = vol_4h > avgVol_4h

// --- Count Alignments ---
int bullAlignment = 0
int bearAlignment = 0

// EMA Alignment
if bull_5m
    bullAlignment += 1
if bull_15m
    bullAlignment += 1
if bull_1h
    bullAlignment += 1
if bull_4h
    bullAlignment += 1

if bear_5m
    bearAlignment += 1
if bear_15m
    bearAlignment += 1
if bear_1h
    bearAlignment += 1
if bear_4h
    bearAlignment += 1

// RSI Alignment
if rsiBull_5m
    bullAlignment += 1
if rsiBull_15m
    bullAlignment += 1
if rsiBull_1h
    bullAlignment += 1
if rsiBull_4h
    bullAlignment += 1

if rsiBear_5m
    bearAlignment += 1
if rsiBear_15m
    bearAlignment += 1
if rsiBear_1h
    bearAlignment += 1
if rsiBear_4h
    bearAlignment += 1

// Volume Alignment
if volAbove_5m
    bullAlignment += 1
if volAbove_15m
    bullAlignment += 1
if volAbove_1h
    bullAlignment += 1
if volAbove_4h
    bullAlignment += 1

if volAbove_5m
    bearAlignment += 1
if volAbove_15m
    bearAlignment += 1
if volAbove_1h
    bearAlignment += 1
if volAbove_4h
    bearAlignment += 1

// --- MTF Strength ---
bullStrengthMTF = bullAlignment * (100 / 12)
bearStrengthMTF = bearAlignment * (100 / 12)
mtfConfidence = math.max(bullStrengthMTF, bearStrengthMTF)

// --- MTF Filter ---
strongBullMTF = bullAlignment >= mtfMinAlignment
strongBearMTF = bearAlignment >= mtfMinAlignment

// --- MTF Weighted Trend ---
weight5m = 10
weight15m = 20
weight1h = 30
weight4h = 40

bullWeightedStrength = (bull_5m ? weight5m : 0) + (bull_15m ? weight15m : 0) + (bull_1h ? weight1h : 0) + (bull_4h ? weight4h : 0)
bearWeightedStrength = (bear_5m ? weight5m : 0) + (bear_15m ? weight15m : 0) + (bear_1h ? weight1h : 0) + (bear_4h ? weight4h : 0)

mtfTrendBull = bullWeightedStrength > bearWeightedStrength
mtfTrendBear = bearWeightedStrength > bullWeightedStrength
mtfTotalStrength = math.max(bullWeightedStrength, bearWeightedStrength)

// ╔══════════════════════════════════════════════════════════════╗
// ║              PART 10 - AI DECISION ENGINE V10              ║
// ╚══════════════════════════════════════════════════════════════╝

// --- MTF Bonus ---
mtfBonus = math.round(mtfTotalStrength * 0.15)
fusionScore = math.min(100, fusionScoreBase + mtfBonus)

// --- AI Confidence Calculation ---
aiConfidenceRaw = math.min(100, math.round(fusionScore * 0.5 + mtfConfidence * 0.3 + (trendStrong ? 20 : 10)))

// --- Institutional Score ---
institutionalScore = math.min(100, math.round(
    (institutionalVolume ? 35 : 15) +
    (smartVolumeBuy or smartVolumeSell ? 25 : 10) +
    (buyVolumeDominant and bullTrend ? 20 : sellVolumeDominant and bearTrend ? 20 : 5) +
    (positiveDelta and bullTrend ? 20 : negativeDelta and bearTrend ? 20 : 5)))

// --- Trend Score ---
trendScore = math.min(100, math.round(
    trendStrengthPercent * 0.35 +
    (bullDI and bullTrend ? 25 : bearDI and bearTrend ? 25 : 5) +
    (emaRising and bullTrend ? 20 : emaFalling and bearTrend ? 20 : 5) +
    (trendAcceleration ? 20 : 10)))

// --- Risk Score ---
riskScore = math.min(100, math.round(riskPercent <= 1 ? 100 : riskPercent <= 2 ? 70 : 40))

// --- Win Probability Estimation ---
winProbability = math.min(95, math.round(fusionScore * 0.4 + mtfConfidence * 0.2 + trendScore * 0.2 + institutionalScore * 0.2))

// --- Final AI Score ---
finalAIScore = math.min(100, math.round(
    aiConfidenceRaw * 0.30 +
    institutionalScore * 0.25 +
    trendScore * 0.25 +
    riskScore * 0.10 +
    winProbability * 0.10))

// --- AI Decision ---
aiDecisionRaw = buyScore >= minimumScore ? "BUY" : sellScore >= minimumScore ? "SELL" : "WAIT"

// --- Apply MTF & Confidence Filters ---
allowLong = (not enableMTF or strongBullMTF) and finalAIScore >= aiMinConfidence
allowShort = (not enableMTF or strongBearMTF) and finalAIScore >= aiMinConfidence

fusionDecision = aiDecisionRaw == "BUY" and allowLong ? "BUY" : aiDecisionRaw == "SELL" and allowShort ? "SELL" : "WAIT"

// --- Arabic Decision ---
aiDecisionArabic = fusionDecision == "BUY" ? "شراء" : fusionDecision == "SELL" ? "بيع" : "انتظار"

// --- AI Grade ---
getAIGrade(score) =>
    if score >= 95
        "A+ ممتاز"
    else if score >= 90
        "A جيد جداً"
    else if score >= 80
        "B جيد"
    else if score >= 70
        "C متوسط"
    else if score >= 60
        "D ضعيف"
    else
        "F سيء"

aiGrade = getAIGrade(finalAIScore)

// --- Trade Quality ---
getTradeQuality(score) =>
    if score >= 90
        "ممتازة A+"
    else if score >= 80
        "جيدة جداً A"
    else if score >= 70
        "جيدة B"
    else if score >= 60
        "متوسطة C"
    else
        "ضعيفة D"

tradeQuality = getTradeQuality(finalAIScore)

// ╔══════════════════════════════════════════════════════════════╗
// ║              PART 11 - ENTRY & EXIT SIGNALS                ║
// ╚══════════════════════════════════════════════════════════════╝

// --- Entry Signals ---
longEntry = fusionDecision == "BUY"
shortEntry = fusionDecision == "SELL"

// --- Price Levels ---
entryPrice = close

// --- Stop Loss ---
longSL = entryPrice - (atrSmart * riskMultiplier)
shortSL = entryPrice + (atrSmart * riskMultiplier)

// --- Risk Calculation ---
longRisk = entryPrice - longSL
shortRisk = shortSL - entryPrice

// --- Targets ---
longTP1 = entryPrice + longRisk * 1.0
longTP2 = entryPrice + longRisk * 2.0
longTP3 = entryPrice + longRisk * 3.0

shortTP1 = entryPrice - shortRisk * 1.0
shortTP2 = entryPrice - shortRisk * 2.0
shortTP3 = entryPrice - shortRisk * 3.0

// --- Risk Reward ---
riskReward = longEntry ? (longTP3 - entryPrice) / math.max(longRisk, 0.0001) : shortEntry ? (entryPrice - shortTP3) / math.max(shortRisk, 0.0001) : na

// --- Position Sizing ---
riskCapital = accountSize * (riskPercent / 100)
stopDistance = longEntry ? entryPrice - longSL : shortEntry ? shortSL - entryPrice : na
positionSize = not na(stopDistance) and stopDistance > 0 ? riskCapital / stopDistance : na

// --- Risk Dollar Amount ---
riskDollar = not na(positionSize) ? positionSize * stopDistance : 0
rewardDollar = not na(positionSize) and not na(riskReward) ? riskDollar * riskReward : 0

// ╔══════════════════════════════════════════════════════════════╗
// ║              PART 12 - DYNAMIC STOP ENGINE V10             ║
// ╚══════════════════════════════════════════════════════════════╝

// --- Trailing Stop ---
trailDistance = atrSmart * trailATR
var float dynamicStop = na
var bool trailActive = false

// Initialize trail on entry
if longEntry and not trailActive
    dynamicStop := close - trailDistance
    trailActive := true

if shortEntry and not trailActive
    dynamicStop := close + trailDistance
    trailActive := true

// Activate trail after reaching activation target
if enableTrail and trailActive
    if longEntry
        if close >= entryPrice + longRisk * trailActivation
            dynamicStop := math.max(dynamicStop, close - trailDistance)
    if shortEntry
        if close <= entryPrice - shortRisk * trailActivation
            dynamicStop := math.min(dynamicStop, close + trailDistance)

// Reset on no position
if not longEntry and not shortEntry
    trailActive := false
    dynamicStop := na

// --- Breakeven ---
var bool breakevenActive = false

if enableBreakeven and longEntry and not breakevenActive
    if close >= entryPrice + longRisk * breakevenTrigger
        dynamicStop := entryPrice
        breakevenActive := true

if enableBreakeven and shortEntry and not breakevenActive
    if close <= entryPrice - shortRisk * breakevenTrigger
        dynamicStop := entryPrice
        breakevenActive := true

if not longEntry and not shortEntry
    breakevenActive := false

// --- Protection Status ---
protectionStatus = enableTrail and trailActive ? "متحرك" : breakevenActive ? "تعادل" : "ثابت"

// ╔══════════════════════════════════════════════════════════════╗
// ║              PART 13 - SMART EXIT ENGINE V10               ║
// ╚══════════════════════════════════════════════════════════════╝

// --- Profit Status ---
inProfitLong = close > entryPrice
inProfitShort = close < entryPrice

// --- Momentum Exit ---
weakLongMomentum = rsiValue < exitRSI
weakShortMomentum = rsiValue > (100 - exitRSI)

// --- Smart Exit ---
smartExitLong = longEntry and inProfitLong and (weakLongMomentum or volumeExhaustion)
smartExitShort = shortEntry and inProfitShort and (weakShortMomentum or volumeExhaustion)

// --- Partial Exit ---
partialExitLong = longEntry and inProfitLong and close >= longTP1 and enablePartialExit
partialExitShort = shortEntry and inProfitShort and close <= shortTP1 and enablePartialExit

// --- Exit Status ---
exitStatus = smartExitLong ? "خروج شراء" : smartExitShort ? "خروج بيع" : partialExitLong ? "جني جزئي" : partialExitShort ? "جني جزئي" : "مستمر"

// ╔══════════════════════════════════════════════════════════════╗
// ║              PART 14 - CHART VISUALIZATIONS                ║
// ║              (ALL bgcolor IN GLOBAL SCOPE)                 ║
// ╚══════════════════════════════════════════════════════════════╝

// --- Heat Map Background ---
heatMapColor = showCharts and enableHeatMap ? (fusionScore >= 90 ? color.new(color.green, 88) : fusionScore >= 80 ? color.new(color.green, 92) : fusionScore >= 70 ? color.new(color.blue, 92) : fusionScore >= 60 ? color.new(color.orange, 92) : fusionScore >= 50 ? color.new(color.red, 92) : na) : na
bgcolor(heatMapColor, title="خريطة الحرارة")

// --- Trend Background ---
trendBgColor = showCharts ? (bullTrend and trendStrong ? color.new(color.green, 90) : bearTrend and trendStrong ? color.new(color.red, 90) : bullTrend ? color.new(color.green, 95) : bearTrend ? color.new(color.red, 95) : na) : na
bgcolor(trendBgColor, title="خلفية الاتجاه")

// --- Momentum Background ---
momentumBgColor = showCharts ? (rsiValue > 70 ? color.new(color.green, 93) : rsiValue > 60 ? color.new(color.green, 95) : rsiValue < 30 ? color.new(color.red, 93) : rsiValue < 40 ? color.new(color.red, 95) : na) : na
bgcolor(momentumBgColor, title="خلفية الزخم")

// --- Strong Signal Highlight ---
signalHighlightColor = showCharts ? (longEntry and fusionScore >= 90 ? color.new(color.green, 85) : shortEntry and fusionScore >= 90 ? color.new(color.red, 85) : na) : na
bgcolor(signalHighlightColor, title="إشارة قوية")

// ╔══════════════════════════════════════════════════════════════╗
// ║              PART 15 - PROFESSIONAL TRADE MAP              ║
// ╚══════════════════════════════════════════════════════════════╝

var line entryLine = na
var line stopLine = na
var line tp1Line = na
var line tp2Line = na
var line tp3Line = na
var label tradeLabel = na
var label sizeLabel = na

if showTradeMap
    if longEntry or shortEntry
        line.delete(entryLine)
        line.delete(stopLine)
        line.delete(tp1Line)
        line.delete(tp2Line)
        line.delete(tp3Line)
        label.delete(tradeLabel)
        label.delete(sizeLabel)

        if longEntry
            entryLine := line.new(bar_index, entryPrice, bar_index + 35, entryPrice, color=color.blue, width=3, style=line.style_solid)
            stopLine := line.new(bar_index, longSL, bar_index + 35, longSL, color=color.red, width=2, style=line.style_dashed)
            tp1Line := line.new(bar_index, longTP1, bar_index + 35, longTP1, color=color.green, width=2, style=line.style_dashed)
            tp2Line := line.new(bar_index, longTP2, bar_index + 35, longTP2, color=color.green, width=2, style=line.style_dashed)
            tp3Line := line.new(bar_index, longTP3, bar_index + 35, longTP3, color=color.green, width=3, style=line.style_solid)
            tradeLabel := label.new(bar_index + 15, entryPrice, "شراء\nRR: " + str.tostring(riskReward, "#.##"), style=label.style_label_center, color=color.green, textcolor=color.white, size=size.small)
            sizeLabel := label.new(bar_index + 25, entryPrice, "الكمية: " + str.tostring(positionSize, "#"), style=label.style_label_center, color=color.blue, textcolor=color.white, size=size.tiny)

        if shortEntry
            entryLine := line.new(bar_index, entryPrice, bar_index + 35, entryPrice, color=color.blue, width=3, style=line.style_solid)
            stopLine := line.new(bar_index, shortSL, bar_index + 35, shortSL, color=color.red, width=2, style=line.style_dashed)
            tp1Line := line.new(bar_index, shortTP1, bar_index + 35, shortTP1, color=color.green, width=2, style=line.style_dashed)
            tp2Line := line.new(bar_index, shortTP2, bar_index + 35, shortTP2, color=color.green, width=2, style=line.style_dashed)
            tp3Line := line.new(bar_index, shortTP3, bar_index + 35, shortTP3, color=color.green, width=3, style=line.style_solid)
            tradeLabel := label.new(bar_index + 15, entryPrice, "بيع\nRR: " + str.tostring(riskReward, "#.##"), style=label.style_label_center, color=color.red, textcolor=color.white, size=size.small)
            sizeLabel := label.new(bar_index + 25, entryPrice, "الكمية: " + str.tostring(positionSize, "#"), style=label.style_label_center, color=color.blue, textcolor=color.white, size=size.tiny)

// ╔══════════════════════════════════════════════════════════════╗
// ║              PART 16 - SMC VISUALIZATION                   ║
// ╚══════════════════════════════════════════════════════════════╝

if enableSmartMoney and showSMC
    if bullishBOS
        label.new(bar_index, low, "كسر هيكل ▲", style=label.style_label_up, color=color.new(color.blue, 20), textcolor=color.white, size=size.small)
    if bearishBOS
        label.new(bar_index, high, "كسر هيكل ▼", style=label.style_label_down, color=color.new(color.blue, 20), textcolor=color.white, size=size.small)
    if choChBull
        label.new(bar_index, low, "تغيير اتجاه ▲", style=label.style_label_up, color=color.new(color.purple, 20), textcolor=color.white, size=size.small)
    if choChBear
        label.new(bar_index, high, "تغيير اتجاه ▼", style=label.style_label_down, color=color.new(color.purple, 20), textcolor=color.white, size=size.small)
    if bullishOB
        box.new(bar_index - 2, low, bar_index + 2, high, border_color=color.green, bgcolor=color.new(color.green, 85), border_width=2, text="OB+")
    if bearishOB
        box.new(bar_index - 2, low, bar_index + 2, high, border_color=color.red, bgcolor=color.new(color.red, 85), border_width=2, text="OB-")
    if bullishFVG
        box.new(bar_index - 2, high[2], bar_index, low, border_color=color.green, bgcolor=color.new(color.green, 80), border_width=1, text="FVG+")
    if bearishFVG
        box.new(bar_index - 2, low[2], bar_index, high, border_color=color.red, bgcolor=color.new(color.red, 80), border_width=1, text="FVG-")
    if liquiditySweepLong
        label.new(bar_index, low, "سحب سيولة ▲", style=label.style_label_up, color=color.new(color.orange, 20), textcolor=color.white, size=size.small)
    if liquiditySweepShort
        label.new(bar_index, high, "سحب سيولة ▼", style=label.style_label_down, color=color.new(color.orange, 20), textcolor=color.white, size=size.small)
    if equalHighs
        label.new(bar_index, high, "قمم متساوية", style=label.style_label_down, color=color.new(color.gray, 30), textcolor=color.white, size=size.tiny)
    if equalLows
        label.new(bar_index, low, "قيعان متساوية", style=label.style_label_up, color=color.new(color.gray, 30), textcolor=color.white, size=size.tiny)

// ╔══════════════════════════════════════════════════════════════╗
// ║              PART 17 - SIGNAL LABELS                       ║
// ╚══════════════════════════════════════════════════════════════╝

if longEntry
    label.new(bar_index, low, "AQE V10 شراء\n" + str.tostring(fusionScore, "#") + "%", style=label.style_label_up, color=color.green, textcolor=color.white, size=size.normal)

if shortEntry
    label.new(bar_index, high, "AQE V10 بيع\n" + str.tostring(fusionScore, "#") + "%", style=label.style_label_down, color=color.red, textcolor=color.white, size=size.normal)

if smartExitLong
    label.new(bar_index, high, "خروج شراء", style=label.style_label_down, color=color.orange, textcolor=color.white, size=size.small)

if smartExitShort
    label.new(bar_index, low, "خروج بيع", style=label.style_label_up, color=color.orange, textcolor=color.white, size=size.small)

if partialExitLong
    label.new(bar_index, high, "جني ربح " + str.tostring(partialExitPercent) + "%", style=label.style_label_down, color=color.yellow, textcolor=color.black, size=size.small)

if partialExitShort
    label.new(bar_index, low, "جني ربح " + str.tostring(partialExitPercent) + "%", style=label.style_label_up, color=color.yellow, textcolor=color.black, size=size.small)

// ╔══════════════════════════════════════════════════════════════╗
// ║              PART 18 - PROFESSIONAL DASHBOARD V10          ║
// ║              (Arabic, Modern, Flicker-free)                ║
// ╚══════════════════════════════════════════════════════════════╝

// --- Color Engine ---
signalColorDB = fusionDecision == "BUY" ? color.rgb(0, 200, 0) : fusionDecision == "SELL" ? color.rgb(255, 50, 50) : color.rgb(255, 165, 0)
confidenceColorDB = finalAIScore >= 80 ? color.rgb(0, 200, 0) : finalAIScore >= 60 ? color.rgb(255, 165, 0) : color.rgb(255, 50, 50)
gradeColorDB = finalAIScore >= 90 ? color.rgb(0, 180, 0) : finalAIScore >= 70 ? color.rgb(0, 120, 255) : finalAIScore >= 50 ? color.rgb(255, 165, 0) : color.rgb(255, 50, 50)
trendColorDB = bullTrend ? color.rgb(0, 180, 0) : bearTrend ? color.rgb(255, 50, 50) : color.rgb(128, 128, 128)
riskColorDB = riskPercent <= 1 ? color.rgb(0, 200, 0) : riskPercent <= 2 ? color.rgb(255, 165, 0) : color.rgb(255, 50, 50)
liquidityColorDB = bullLiquidity ? color.rgb(0, 180, 0) : bearLiquidity ? color.rgb(255, 50, 50) : color.rgb(128, 128, 128)
volumeColorDB = institutionalVolume ? color.rgb(0, 180, 0) : strongVolume ? color.rgb(0, 120, 255) : weakVolume ? color.rgb(255, 50, 50) : color.rgb(128, 128, 128)
sessionColorDB = sessionName == "لندن" ? color.rgb(0, 120, 255) : sessionName == "نيويورك" ? color.rgb(0, 180, 0) : sessionName == "آسيا" ? color.rgb(255, 200, 0) : color.rgb(128, 128, 128)

// --- Dashboard Table ---
var table dashTable = table.new(position.top_right, 2, 21, border_width=0, frame_width=0, bgcolor=color.rgb(10, 10, 15, 90))

if barstate.islast and showDashboard
    // Row 0 - Title
    table.cell(dashTable, 0, 0, "AQE V10", text_color=color.rgb(255, 255, 255), bgcolor=color.rgb(0, 80, 200), text_size=size.large, width=100)
    table.cell(dashTable, 1, 0, "PRO", text_color=color.rgb(255, 255, 255), bgcolor=color.rgb(0, 80, 200), text_size=size.large, width=100)

    // Row 1 - القرار
    table.cell(dashTable, 0, 1, "القرار", text_color=color.rgb(180, 180, 180), bgcolor=na, width=100)
    table.cell(dashTable, 1, 1, aiDecisionArabic, text_color=color.white, bgcolor=signalColorDB, width=100)

    // Row 2 - الثقة
    table.cell(dashTable, 0, 2, "الثقة", text_color=color.rgb(180, 180, 180), bgcolor=na)
    table.cell(dashTable, 1, 2, str.tostring(finalAIScore, "#") + "%", text_color=color.white, bgcolor=confidenceColorDB)

    // Row 3 - درجة AI
    table.cell(dashTable, 0, 3, "درجة AI", text_color=color.rgb(180, 180, 180), bgcolor=na)
    table.cell(dashTable, 1, 3, aiGrade, text_color=color.white, bgcolor=gradeColorDB)

    // Row 4 - جودة الإشارة
    table.cell(dashTable, 0, 4, "جودة الإشارة", text_color=color.rgb(180, 180, 180), bgcolor=na)
    table.cell(dashTable, 1, 4, tradeQuality, text_color=color.white, bgcolor=gradeColorDB)

    // Row 5 - احتمال النجاح
    table.cell(dashTable, 0, 5, "احتمال النجاح", text_color=color.rgb(180, 180, 180), bgcolor=na)
    table.cell(dashTable, 1, 5, str.tostring(winProbability, "#") + "%", text_color=color.white, bgcolor=confidenceColorDB)

    // Row 6 - اتجاه السوق
    table.cell(dashTable, 0, 6, "اتجاه السوق", text_color=color.rgb(180, 180, 180), bgcolor=na)
    marketText = bullTrend ? "صاعد" : bearTrend ? "هابط" : "عرضي"
    table.cell(dashTable, 1, 6, marketText, text_color=color.white, bgcolor=trendColorDB)

    // Row 7 - حالة السوق
    table.cell(dashTable, 0, 7, "حالة السوق", text_color=color.rgb(180, 180, 180), bgcolor=na)
    table.cell(dashTable, 1, 7, marketPhase, text_color=color.white, bgcolor=trendColorDB)

    // Row 8 - قوة الاتجاه %
    table.cell(dashTable, 0, 8, "قوة الاتجاه", text_color=color.rgb(180, 180, 180), bgcolor=na)
    table.cell(dashTable, 1, 8, str.tostring(trendStrengthPercent, "#") + "%", text_color=color.white, bgcolor=trendStrong ? color.rgb(0, 180, 0) : color.rgb(255, 165, 0))

    // Row 9 - قوة المؤسسات
    table.cell(dashTable, 0, 9, "قوة المؤسسات", text_color=color.rgb(180, 180, 180), bgcolor=na)
    table.cell(dashTable, 1, 9, str.tostring(institutionalScore, "#") + "%", text_color=color.white, bgcolor=institutionalScore >= 70 ? color.rgb(0, 180, 0) : color.rgb(255, 165, 0))

    // Row 10 - حالة السيولة
    table.cell(dashTable, 0, 10, "حالة السيولة", text_color=color.rgb(180, 180, 180), bgcolor=na)
    liquidityText = liquiditySweepLong ? "سحب شرائي" : liquiditySweepShort ? "سحب بيعي" : bullLiquidity ? "شرائية" : bearLiquidity ? "بيعية" : "محايدة"
    table.cell(dashTable, 1, 10, liquidityText, text_color=color.white, bgcolor=liquidityColorDB)

    // Row 11 - قوة الحجم
    table.cell(dashTable, 0, 11, "قوة الحجم", text_color=color.rgb(180, 180, 180), bgcolor=na)
    volumeText = institutionalVolume ? "مؤسسي قوي" : smartVolumeBuy or smartVolumeSell ? "ذكي" : strongVolume ? "قوي" : weakVolume ? "ضعيف" : "عادي"
    table.cell(dashTable, 1, 11, volumeText, text_color=color.white, bgcolor=volumeColorDB)

    // Row 12 - توافق الفريمات
    table.cell(dashTable, 0, 12, "توافق الفريمات", text_color=color.rgb(180, 180, 180), bgcolor=na)
    table.cell(dashTable, 1, 12, str.tostring(bullAlignment) + "/12", text_color=color.white, bgcolor=strongBullMTF ? color.rgb(0, 180, 0) : strongBearMTF ? color.rgb(255, 50, 50) : color.rgb(255, 165, 0))

    // Row 13 - الجلسة
    table.cell(dashTable, 0, 13, "الجلسة", text_color=color.rgb(180, 180, 180), bgcolor=na)
    table.cell(dashTable, 1, 13, sessionName + (isKillZone ? " 🔥" : ""), text_color=color.white, bgcolor=sessionColorDB)

    // Row 14 - الزخم
    table.cell(dashTable, 0, 14, "الزخم", text_color=color.rgb(180, 180, 180), bgcolor=na)
    momentumText = rsiValue > 60 ? "قوي" : rsiValue < 40 ? "ضعيف" : "محايد"
    momentumColorDB = rsiValue > 60 ? color.rgb(0, 180, 0) : rsiValue < 40 ? color.rgb(255, 50, 50) : color.rgb(255, 165, 0)
    table.cell(dashTable, 1, 14, momentumText, text_color=color.white, bgcolor=momentumColorDB)

    // Row 15 - حالة ATR
    table.cell(dashTable, 0, 15, "حالة التذبذب", text_color=color.rgb(180, 180, 180), bgcolor=na)
    atrText = volatilityExpanding ? "متوسع" : volatilityContracting ? "متقلص" : "عادي"
    atrColorDB = volatilityExpanding ? color.rgb(255, 50, 50) : volatilityContracting ? color.rgb(0, 180, 0) : color.rgb(255, 165, 0)
    table.cell(dashTable, 1, 15, atrText, text_color=color.white, bgcolor=atrColorDB)

    // Row 16 - المخاطرة
    table.cell(dashTable, 0, 16, "المخاطرة", text_color=color.rgb(180, 180, 180), bgcolor=na)
    riskText = riskPercent <= 1 ? "آمنة" : riskPercent <= 2 ? "متوسطة" : "عالية"
    table.cell(dashTable, 1, 16, riskText, text_color=color.white, bgcolor=riskColorDB)

    // Row 17 - الهدف الأول
    table.cell(dashTable, 0, 17, "الهدف ١", text_color=color.rgb(180, 180, 180), bgcolor=na)
    tp1Text = longEntry ? str.tostring(longTP1, "#.##") : shortEntry ? str.tostring(shortTP1, "#.##") : "-"
    table.cell(dashTable, 1, 17, tp1Text, text_color=color.white, bgcolor=color.rgb(0, 150, 0, 50))

    // Row 18 - الهدف الثاني
    table.cell(dashTable, 0, 18, "الهدف ٢", text_color=color.rgb(180, 180, 180), bgcolor=na)
    tp2Text = longEntry ? str.tostring(longTP2, "#.##") : shortEntry ? str.tostring(shortTP2, "#.##") : "-"
    table.cell(dashTable, 1, 18, tp2Text, text_color=color.white, bgcolor=color.rgb(0, 120, 0, 40))

    // Row 19 - الهدف الثالث
    table.cell(dashTable, 0, 19, "الهدف ٣", text_color=color.rgb(180, 180, 180), bgcolor=na)
    tp3Text = longEntry ? str.tostring(longTP3, "#.##") : shortEntry ? str.tostring(shortTP3, "#.##") : "-"
    table.cell(dashTable, 1, 19, tp3Text, text_color=color.white, bgcolor=color.rgb(0, 100, 0, 30))

    // Row 20 - وقف الخسارة
    table.cell(dashTable, 0, 20, "وقف الخسارة", text_color=color.rgb(180, 180, 180), bgcolor=na)
    slText = longEntry ? str.tostring(longSL, "#.##") : shortEntry ? str.tostring(shortSL, "#.##") : "-"
    table.cell(dashTable, 1, 20, slText, text_color=color.white, bgcolor=color.rgb(200, 0, 0, 50))

// ╔══════════════════════════════════════════════════════════════╗
// ║              PART 19 - ALERTS SYSTEM V10                   ║
// ╚══════════════════════════════════════════════════════════════╝

// --- Entry Alerts ---
alertcondition(longEntry and alertBuy, "AQE V10 - شراء", "إشارة شراء AQE V10")
alertcondition(shortEntry and alertSell, "AQE V10 - بيع", "إشارة بيع AQE V10")

// --- Exit Alerts ---
alertcondition(smartExitLong and alertExit, "AQE V10 - خروج شراء", "إشارة خروج شراء")
alertcondition(smartExitShort and alertExit, "AQE V10 - خروج بيع", "إشارة خروج بيع")
alertcondition(partialExitLong and alertExit, "AQE V10 - جني ربح شراء", "جني ربح جزئي شراء")
alertcondition(partialExitShort and alertExit, "AQE V10 - جني ربح بيع", "جني ربح جزئي بيع")

// --- SMC Alerts ---
alertcondition(bullishBOS and alertSMC, "AQE V10 - كسر هيكل صاعد", "كسر هيكل صاعد")
alertcondition(bearishBOS and alertSMC, "AQE V10 - كسر هيكل هابط", "كسر هيكل هابط")
alertcondition(choChBull and alertSMC, "AQE V10 - تغيير اتجاه صاعد", "تغيير اتجاه صاعد")
alertcondition(choChBear and alertSMC, "AQE V10 - تغيير اتجاه هابط", "تغيير اتجاه هابط")
alertcondition(bullishFVG and alertSMC, "AQE V10 - فجوة صاعدة", "فجوة قيمة عادلة صاعدة")
alertcondition(bearishFVG and alertSMC, "AQE V10 - فجوة هابطة", "فجوة قيمة عادلة هابطة")
alertcondition(liquiditySweepLong and alertSMC, "AQE V10 - سحب سيولة صاعد", "سحب سيولة صاعد")
alertcondition(liquiditySweepShort and alertSMC, "AQE V10 - سحب سيولة هابط", "سحب سيولة هابط")

// --- Trend Change Alerts ---
alertcondition(bullTrend and not bullTrend[1] and alertTrend, "AQE V10 - تغير اتجاه صاعد", "تغير الاتجاه إلى صاعد")
alertcondition(bearTrend and not bearTrend[1] and alertTrend, "AQE V10 - تغير اتجاه هابط", "تغير الاتجاه إلى هابط")

// --- Strong Signal Alerts ---
alertcondition(longEntry and fusionScore >= 90 and alertBuy, "AQE V10 - شراء قوي", "إشارة شراء قوية AQE V10")
alertcondition(shortEntry and fusionScore >= 90 and alertSell, "AQE V10 - بيع قوي", "إشارة بيع قوية AQE V10")

// ╔══════════════════════════════════════════════════════════════╗
// ║              PART 20 - SCORE PLOT                          ║
// ╚══════════════════════════════════════════════════════════════╝

scoreColor = finalAIScore >= 80 ? color.rgb(0, 200, 0) : finalAIScore >= 60 ? color.rgb(255, 165, 0) : color.rgb(255, 50, 50)
plot(finalAIScore, "AQE Fusion Score", color=scoreColor, linewidth=2, style=plot.style_columns)

